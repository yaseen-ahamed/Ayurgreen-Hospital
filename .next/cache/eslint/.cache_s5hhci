,[29000,29003],[29014,29017],[29014,29017],[37521,37524],[37521,37524],[38765,38768],[38765,38768],[38784,38787],[38784,38787],[27,42],[57,112],[1481,1854],"\n                        ADMIRE represents Ayurgreen Hospital&apos;s 25 years of experience in neuro-rehabilitation, bringing\n                        together Ayurveda, Physiotherapy, Occupational Therapy, Speech Therapy, Robotics, and modern\n                        medicine under one integrated, patient-centered approach designed to restore independence.\n                    ",[1481,1854],"\n                        ADMIRE represents Ayurgreen Hospital&lsquo;s 25 years of experience in neuro-rehabilitation, bringing\n                        together Ayurveda, Physiotherapy, Occupational Therapy, Speech Therapy, Robotics, and modern\n                        medicine under one integrated, patient-centered approach designed to restore independence.\n                    ",[1481,1854],"\n                        ADMIRE represents Ayurgreen Hospital&#39;s 25 years of experience in neuro-rehabilitation, bringing\n                        together Ayurveda, Physiotherapy, Occupational Therapy, Speech Therapy, Robotics, and modern\n                        medicine under one integrated, patient-centered approach designed to restore independence.\n                    ",[1481,1854],"\n                        ADMIRE represents Ayurgreen Hospital&rsquo;s 25 years of experience in neuro-rehabilitation, bringing\n                        together Ayurveda, Physiotherapy, Occupational Therapy, Speech Therapy, Robotics, and modern\n                        medicine under one integrated, patient-centered approach designed to restore independence.\n                    ",[27,42],[57,112],[27,42],[57,112],[27,42],[57,112],[27,42],[57,112],[21696,21710],"Doctor&apos;s visit",[21696,21710],"Doctor&lsquo;s visit",[21696,21710],"Doctor&#39;s visit",[21696,21710],"Doctor&rsquo;s visit",[27,42],[57,112],[1259,1262],[1259,1262],[1624,1627],[1624,1627],[13581,13600],"Parkinson&apos;s Disease",[13581,13600],"Parkinson&lsquo;s Disease",[13581,13600],"Parkinson&#39;s Disease",[13581,13600],"Parkinson&rsquo;s Disease",[29168,29171],[29168,29171],[29484,29487],[29484,29487],[35489,35492],[35489,35492],[35808,35811],[35808,35811],[27,42],[57,112],[4403,4406],[4403,4406],[4722,4725],[4722,4725],[27,42],[57,112],[972,1377],"\n              As India&apos;s first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body's biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India&lsquo;s first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body's biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India&#39;s first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body's biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India&rsquo;s first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body's biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India's first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body&apos;s biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India's first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body&lsquo;s biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India's first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body&#39;s biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[972,1377],"\n              As India's first robotic-integrated neuro rehabilitation center, we combine the pinpoint precision of modern robotic technology with the deep, systemic healing of Ayurveda — training the body&rsquo;s biomechanics using advanced machines while simultaneously nurturing the nervous system with time-tested holistic therapies, resulting in faster and more sustainable recovery outcomes.\n            ",[829,832],[829,832],"Award",[91,97],"ShieldCheck",[102,115],[2101,2104],[2101,2104],[854,857],[854,857]]