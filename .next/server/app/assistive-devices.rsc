"lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["assistive-devices",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","assistive-devices","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"assistive-devices","sidebarId":"assistive-devices","metaTitle":"Assistive Devices | Ayurgreen Hospital","metaDescription":"Assessing, custom fitting, and training on wheelchairs, splints, orthotics, and communication aids to elevate daily function.","canonicalPath":"/assistive-devices","hero":{"bannerImage":"Assets/rehab/th_ot.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Assistive Devices","subtitle":"Assessing, custom fitting, and training on wheelchairs, splints, orthotics, and communication aids to elevate daily function."},"overview":{"sectionLabel":"OVERVIEW","title":"Assistive Devices: Technology for Independence","paragraphs":["Assistive devices and adaptive technology bridge the gap between physical limitation and functional independence. The right device — whether a specialized wheelchair, a communication aid, an adapted eating utensil, or an environmental control system — can transform a person's level of independence, dignity, and quality of life.","At Ayurgreen Hospital, our Assistive Technology and Device Service provides expert assessment, prescription, fitting, and training for the full range of assistive devices needed by our rehabilitation population. Our occupational therapists, physiotherapists, and speech therapists work together to ensure each patient receives the most appropriate devices for their specific functional needs.","We believe that assistive devices should not be the treatment of last resort — they should be proactively incorporated from the earliest stages of rehabilitation, enabling patients to participate in daily life and therapy while their underlying function continues to improve."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Assistive Devices at Ayurgreen Hospital"},"conditions":{"sectionLabel":"ASSISTIVE DEVICE CATEGORIES","sectionTitle":"Assistive Devices We Prescribe & Train","sectionSupport":"Expert assessment and provision of assistive technology for mobility, communication, self-care, and environmental control.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Mobility & Positioning Aids","description":"Specialized wheelchairs (manual, powered, tilt-in-space), walking aids (canes, crutches, walking frames, forearm crutches), orthoses (ankle-foot orthoses, knee-ankle-foot orthoses), and positioning equipment."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Communication & AAC Technology","description":"Augmentative and Alternative Communication (AAC) devices from simple communication boards and PECS to high-tech speech-generating devices (SGDs) and eye-gaze communication systems for non-verbal patients."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Adaptive Self-Care Equipment","description":"Specialized equipment for independence in daily activities: one-handed kitchen aids, modified utensils, dressing aids, bath equipment, and home modification recommendations for safety and independence."}]},"treatments":{"sectionLabel":"ASSISTIVE DEVICE SERVICES","sectionTitle":"Comprehensive Assistive Technology Services","sectionSupport":"Expert assessment, prescription, and training in assistive technology for maximum patient independence.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Assistive Technology Assessment & Prescription","description":"Comprehensive functional assessment by our occupational therapists and physiotherapists to identify the most appropriate assistive devices for each patient's specific needs, environment, and goals. Trials of multiple device options before prescription. Consideration of the patient's current function, future recovery potential, home environment, family support, and financial circumstances in all device recommendations."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Specialized Wheelchair & Seating Assessment","description":"Expert wheelchair assessment for optimal seating posture, pressure relief, mobility function, and accessibility. Prescription of the most appropriate wheelchair type: standard manual, lightweight active user chair, tilt-in-space, or powered wheelchair. Custom seating and pressure-relieving cushions for high-risk patients. Caregiver training in wheelchair management, transfers, and maintenance."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"AAC Technology for Communication","description":"Expert AAC assessment and device prescription for non-verbal or minimally verbal patients. High-tech eye-gaze systems and brain-computer interfaces for patients with severe motor impairment (locked-in syndrome, severe ALS). PECS and low-tech communication systems for patients with cognitive or motor limitations. Training of patients, families, and therapy teams in AAC use to ensure successful communication across all settings."},{"image":"Assets/rehab/th_robotic.webp","title":"Environmental Control & Smart Home Technology","description":"Environmental control systems (ECS) allowing patients with severe motor impairment to independently control their environment — lights, TV, doors, telephone, computer — using switch access, voice control, or eye gaze. Smart home technology integration enabling maximum independence at home for severely disabled patients. Assessment for powered wheelchair control and computer access with alternative input methods."}]},"technologies":{"sectionLabel":"ASSISTIVE TECHNOLOGY","sectionTitle":"Advanced Assistive Technology & Devices","sectionSupport":"The most comprehensive range of assistive technology available for neurological and physical rehabilitation patients.","cards":[{"icon":"accessibility","title":"Powered Wheelchairs & Seating","description":"Advanced powered wheelchairs with joystick, head array, and sip-and-puff controls for patients with severe motor impairment — enabling mobility independence despite significant physical limitations."},{"icon":"mic","title":"Eye-Gaze AAC Systems","description":"High-tech eye-tracking communication systems allowing patients with complete loss of voluntary movement to communicate through eye movements — the most sophisticated communication technology available."},{"icon":"zap","title":"Functional Electrical Stimulation Orthoses","description":"FES drop-foot stimulators and hand-opening stimulators — devices using electrical muscle stimulation to enable functional movement in paralyzed limbs during everyday activities."},{"icon":"puzzle","title":"Adaptive Equipment Library","description":"Extensive adaptive equipment library for trial and loan — allowing patients to test devices before prescription and providing immediate access to specialized equipment during rehabilitation."},{"icon":"home","title":"Smart Home & Environmental Control","description":"Comprehensive smart home technology assessment and implementation for discharge — voice-controlled systems, automated lighting, smart locks, and remote monitoring enabling maximum home independence."}]},"faq":{"sectionSupport":"Find answers to key details about the Assistive Devices program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Assistive Devices combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","HxXMdoW-LSFCLSfA2s2_B",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
