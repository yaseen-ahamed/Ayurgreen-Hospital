en":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["autism",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","autism","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"autism","sidebarId":"autism","metaTitle":"Autism Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Pediatric sensory integration, motor coordination retraining, and gentle behavioral guidance protocols.","canonicalPath":"/autism","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Autism.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Autism","subtitle":"Pediatric sensory integration, motor coordination retraining, and gentle behavioral guidance protocols."},"overview":{"sectionLabel":"OVERVIEW","title":"Autism Spectrum Disorder: Specialized Support for Every Child","paragraphs":["Autism Spectrum Disorder (ASD) is a complex neurodevelopmental condition characterized by challenges in social communication and interaction, alongside restricted and repetitive behaviors and interests. It exists on a broad spectrum — from individuals who are non-speaking and require significant daily support, to those who are highly verbal and academically capable but struggle with social interaction and sensory processing.","At Ayurgreen Hospital, our Autism Specialist Program provides expert, evidence-based, family-centered support for children and young adults with ASD. We do not offer a 'cure' for autism — autism is a neurological difference, not a disease. Our goal is to help each autistic individual develop the skills and strategies to communicate, learn, participate, and thrive in their communities.","Our program combines the most evidence-based behavioral and developmental interventions (ABA, DIR/Floortime, ESDM) with specialized speech, occupational, and sensory therapies — and uniquely integrates Ayurvedic approaches that are emerging as supportive in managing ASD-related GI issues, sleep disorders, and anxiety."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Autism at Ayurgreen Hospital"},"conditions":{"sectionLabel":"ASD SUPPORT AREAS","sectionTitle":"Autism Challenges We Support","sectionSupport":"Comprehensive, evidence-based support addressing the communication, behavioral, sensory, and health challenges of ASD.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Communication & Social Skills","description":"Non-verbal and minimally verbal autism with AAC support, early language intervention, ESDM programs, and social communication groups for verbal autistic individuals."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Behavioral & Emotional Regulation","description":"ABA therapy for challenging behaviors, functional behavior assessments, PBS (Positive Behavior Support) plans, and anxiety management strategies for autistic children and young adults."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Sensory Processing & Motor Skills","description":"Sensory integration therapy for hypersensitivity and hyposensitivity, proprioceptive and vestibular interventions, fine and gross motor skill development, and sensory diet programs."}]},"treatments":{"sectionLabel":"ASD INTERVENTION PROGRAM","sectionTitle":"Comprehensive Autism Support Services","sectionSupport":"Evidence-based, family-centered ASD support across communication, behavioral, sensory, and holistic health dimensions.","steps":[{"image":"Assets/rehab/th_speech.webp","title":"Speech, Language & Communication Intervention","description":"Comprehensive speech therapy targeting each child's specific communication needs: ESDM (Early Start Denver Model) for young children; AAC systems (PECS, SGDs, high-tech eye-gaze devices) for non-speaking autistic children; Social Communication intervention for verbal children; Pragmatic language groups for peer interaction skills; and parent coaching to support communication development at home."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Sensory Integration & Occupational Therapy","description":"Ayers Sensory Integration (ASI) therapy addressing the sensory processing differences common in autism — tactile defensiveness, proprioceptive seeking, vestibular hypersensitivity. Individualized sensory diets prescribed to regulate arousal and improve participation. Fine motor skills, handwriting, and self-care independence training. Environmental modification recommendations for home and school."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic & Holistic Support","description":"Ayurveda offers specific support for the co-occurring health challenges common in autism: GI dysbiosis and constipation (managed with Basti therapy and probiotic formulations); sleep disorders (managed with Ashwagandha and Shirodhara); anxiety and emotional dysregulation (Brahmi, Jatamansi formulations and Abhyanga with calming oils); and the overall neurological health support of Medhya Rasayana therapy."},{"image":"Assets/rehab/prog_stroke.webp","title":"Applied Behavior Analysis (ABA) & Behavioral Support","description":"Evidence-based ABA therapy for skill development (communication, self-care, academic, social) and management of challenging behaviors through positive reinforcement strategies. Functional Behavior Assessments (FBAs) identify the function of challenging behaviors, informing individualized Behavior Support Plans (BSPs) implemented consistently across home, school, and therapy settings."}]},"technologies":{"sectionLabel":"ASD SUPPORT TECHNOLOGY","sectionTitle":"Technology & Approaches for ASD Support","sectionSupport":"Evidence-based tools and therapies for comprehensive autism spectrum disorder support.","cards":[{"icon":"mic","title":"AAC Communication Systems","description":"High-tech SGDs, PECS systems, and eye-gaze communication devices ensuring every non-verbal autistic child and young adult has a functional communication system."},{"icon":"activity","title":"Sensory Integration Suite","description":"Specialized sensory gym with swings, climbing structures, and tactile materials for Ayers Sensory Integration therapy targeting sensory processing differences in autism."},{"icon":"headset","title":"VR Social Skills Training","description":"Virtual reality environments for safe, controlled social skills practice — allowing autistic individuals to rehearse social scenarios in a low-stress, repeatable virtual environment."},{"icon":"leaf","title":"Ayurvedic GI & Sleep Support","description":"Basti therapy for GI dysbiosis and constipation, Brahmi and Ashwagandha for anxiety and sleep, and Abhyanga for sensory regulation and calming — supporting the co-occurring health challenges of autism."},{"icon":"heart-handshake","title":"Family Training & Support","description":"Intensive parent training in ABA principles, communication strategies, and sensory diet implementation — ensuring evidence-based support continues at home 24/7."}]},"faq":{"sectionSupport":"Find answers to key details about the Autism program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Autism combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","gktLjho8quvq8zT63LWTs",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
