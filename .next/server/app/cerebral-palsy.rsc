8:T663,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/cerebral-palsy#webpage","url":"https://ayurgreenhospital.com/cerebral-palsy","name":"Cerebral Palsy Rehabilitation & Care | Ayurgreen Hospital","description":"Specialized pediatric neurodevelopmental therapies to help reduce rigid muscle stiffness and assist milestone achievements.","about":{"@type":"MedicalSpecialty","name":"Integrated Cerebral Palsy Rehabilitation"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/cerebral-palsy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Specialities","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Cerebral Palsy","item":"https://ayurgreenhospital.com/cerebral-palsy"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/cerebral-palsy#service","name":"Cerebral Palsy Rehabilitation","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Specialized pediatric neurodevelopmental therapies to help reduce rigid muscle stiffness and assist milestone achievements."}]}0:{"P":null,"b":"LiUuSPa93huxu4xcSB3P5","p":"","c":["","cerebral-palsy"],"i":false,"f":[[["",{"children":["cerebral-palsy",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"