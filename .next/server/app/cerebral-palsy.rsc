:500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["cerebral-palsy",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","cerebral-palsy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"cerebral-palsy","sidebarId":"cerebral-palsy","metaTitle":"Cerebral Palsy Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Specialized pediatric neurodevelopmental therapies to help reduce rigid muscle stiffness and assist milestone achievements.","canonicalPath":"/cerebral-palsy","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Cerebral Palsy.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Cerebral Palsy","subtitle":"Specialized pediatric neurodevelopmental therapies to help reduce rigid muscle stiffness and assist milestone achievements."},"overview":{"sectionLabel":"OVERVIEW","title":"Cerebral Palsy Rehabilitation: Unlocking Every Child's Potential","paragraphs":["Cerebral Palsy (CP) is a group of permanent movement disorders caused by damage to the developing brain — before, during, or shortly after birth. It is the most common cause of physical disability in childhood, affecting movement, muscle tone, posture, and balance in varying degrees.","At Ayurgreen Hospital, our Cerebral Palsy Rehabilitation Program is one of the most specialized and comprehensive in India. We believe that every child with CP has the potential to reach their maximum functional independence — and we use every tool at our disposal to help them achieve it.","Our integrated program combines robotic technology, Neurodevelopmental Therapy (NDT), Constraint-Induced Movement Therapy (CIMT), intensive physiotherapy and occupational therapy, speech therapy, and authentic Ayurvedic therapies specifically adapted for children — creating a holistic healing environment where each child thrives."],"image":"Assets/rehab/prog_spinal_cord.webp","imageAlt":"Cerebral Palsy at Ayurgreen Hospital"},"conditions":{"sectionLabel":"CP TYPES WE TREAT","sectionTitle":"Cerebral Palsy Types We Specialize In","sectionSupport":"Expert rehabilitation for all types and severities of cerebral palsy, from hemiplegic to quadriplegic CP.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Spastic Cerebral Palsy (Hemi, Di, Quad)","description":"The most common type — characterized by muscle stiffness and spasticity. Hemiplegic (one side), diplegic (both legs), and quadriplegic (all four limbs) spastic CP each have specific rehabilitation approaches using robotic systems, Botox, and Ayurvedic spasticity management."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Dyskinetic & Athetoid CP","description":"Characterized by involuntary, uncontrolled movements. Our program uses sensory integration therapy, specialized physiotherapy, and Ayurvedic calming therapies to improve movement control and reduce involuntary movements."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Ataxic & Mixed Cerebral Palsy","description":"Ataxic CP with poor balance and coordination is addressed through intensive balance training and the Huber 360 platform. Mixed CP types are comprehensively managed with customized programs targeting each component of the child's presentation."}]},"treatments":{"sectionLabel":"CP REHABILITATION","sectionTitle":"Comprehensive Cerebral Palsy Rehabilitation","sectionSupport":"Integrated, family-centered rehabilitation that addresses every aspect of a child's development and functional needs.","steps":[{"image":"Assets/rehab/th_robotic.webp","title":"Robotic & Technology-Assisted Therapy","description":"Our robotic systems are adapted for pediatric use: the Armotion provides guided arm therapy for hemiplegic CP; the G-EO system provides supported walking practice for children who cannot yet walk independently; and the Huber 360 provides balance and core strengthening for ataxic and diplegic CP. These systems deliver the volume and precision of movement training critical for pediatric neuroplasticity."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"NDT, CIMT & Intensive Physiotherapy","description":"Neurodevelopmental Therapy (NDT/Bobath) is the foundation of our physiotherapy program for CP, addressing tone, posture, and functional movement patterns. Constraint-Induced Movement Therapy (CIMT) and Hand-Arm Bimanual Intensive Therapy (HABIT) maximize arm function in hemiplegic CP. Intensive physiotherapy for gait retraining, balance, and muscle strengthening."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Therapies for Cerebral Palsy","description":"Kerala Ayurveda has a rich tradition of therapies for developmental movement disorders. Abhyanga (oil massage) with specific medicated oils reduces spasticity and promotes sensorimotor development; Njavara Kizhi strengthens weak muscles; Shirodhara calms the nervous system in dyskinetic CP; and Medhya Rasayana formulations (Brahmi, Shatavari) support cognitive development and neuroprotection."},{"image":"Assets/rehab/th_speech.webp","title":"Speech Therapy & Occupational Therapy","description":"Comprehensive speech therapy for CP-related communication disorders (dysarthria, AAC), feeding difficulties, and language delay. Occupational therapy for fine motor development, sensory integration, adaptive equipment prescription, school participation, and independence in all ADLs — helping each child achieve their maximum educational and social participation."}]},"technologies":{"sectionLabel":"CP REHABILITATION TECHNOLOGY","sectionTitle":"Advanced Technology for CP Rehabilitation","sectionSupport":"Specialized pediatric robotic and therapeutic technology for maximum developmental progress in cerebral palsy.","cards":[{"icon":"bot","title":"Pediatric Robotic Gait Training","description":"G-EO and supported walking systems adapted for children, providing body-weight support and guided gait training to promote walking development in non-ambulant CP children."},{"icon":"hand","title":"Armotion Upper Limb Therapy","description":"Robotic guided arm therapy for hemiplegic CP children, combined with CIMT to maximize use and development of the affected arm."},{"icon":"activity","title":"Huber 360 Balance Training","description":"Dynamic balance, coordination, and core strength training for ataxic and diplegic CP — improving postural stability and walking ability through interactive programs."},{"icon":"leaf","title":"Ayurvedic Neurodevelopment","description":"Traditional Kerala Ayurvedic therapies (Abhyanga, Njavara Kizhi, Brahmi Rasayana) specifically adapted for children to reduce spasticity, strengthen muscles, and support healthy neurodevelopment."},{"icon":"syringe","title":"Botox for Spasticity","description":"Targeted botulinum toxin injections to reduce focal spasticity (calf, hamstring, hip adductors) — creating a window for intensive physiotherapy to maximize functional gains in spastic CP."}]},"faq":{"sectionSupport":"Find answers to key details about the Cerebral Palsy program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Cerebral Palsy combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","OXYUVJias2ZIdcYv6KcIu",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
