8:T5f1,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/counseling#webpage","url":"https://ayurgreenhospital.com/counseling","name":"Counseling | Ayurgreen Hospital","description":"Clinical counseling and mental health support to help patients and families navigate the emotional recovery journey.","about":{"@type":"MedicalSpecialty","name":"Counseling"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/counseling#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Departments","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Counseling","item":"https://ayurgreenhospital.com/counseling"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/counseling#service","name":"Counseling","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Clinical counseling and mental health support to help patients and families navigate the emotional recovery journey."}]}0:{"P":null,"b":"8fOA1jbl6pU7Z3DXp6zXJ","p":"","c":["","counseling"],"i":false,"f":[[["",{"children":["counseling",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$