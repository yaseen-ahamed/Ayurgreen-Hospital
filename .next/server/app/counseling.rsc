dren":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["counseling",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","counseling","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"counseling","sidebarId":"counseling","metaTitle":"Counseling | Ayurgreen Hospital","metaDescription":"Clinical counseling and mental health support to help patients and families navigate the emotional recovery journey.","canonicalPath":"/counseling","hero":{"bannerImage":"Assets/rehab/th_vr.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Counseling","subtitle":"Clinical counseling and mental health support to help patients and families navigate the emotional recovery journey."},"overview":{"sectionLabel":"OVERVIEW","title":"Counseling: Compassionate Support for Mind & Spirit","paragraphs":["A medical journey — whether recovering from stroke, living with a chronic neurological condition, or facing a life-altering disability — is not only a physical experience. It profoundly affects emotions, relationships, identity, and sense of purpose. Compassionate, skilled counseling is essential to support both patients and families through these challenges.","At Ayurgreen Hospital, professional counseling is provided as an integral component of all rehabilitation programs — not as a separate service to be requested, but as a proactive, embedded dimension of care. Our trained counselors and clinical psychologists routinely screen all patients and families for psychological needs and provide responsive, personalized support.","Our counseling services bridge the gap between the clinical expertise of our medical team and the human experience of our patients and families — ensuring that the emotional, relational, and spiritual dimensions of recovery receive the same expert attention as the physical dimensions."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Counseling at Ayurgreen Hospital"},"conditions":{"sectionLabel":"COUNSELING FOCUS AREAS","sectionTitle":"What Our Counselors Address","sectionSupport":"Compassionate, professional counseling for the emotional, relational, and psychological challenges of illness and rehabilitation.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Patient Emotional Support","description":"Addressing the depression, anxiety, grief, loss, fear, anger, and adjustment challenges that accompany sudden disability, chronic illness, and long rehabilitation journeys."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Family & Relationship Counseling","description":"Supporting families through the significant stress, role changes, relationship strain, and grief that accompanies caring for a family member with serious illness or disability."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Caregiver Wellbeing & Burnout Prevention","description":"Dedicated caregiver support addressing the burden, burnout, compassion fatigue, and depression that commonly affect those caring for neurologically impaired family members."}]},"treatments":{"sectionLabel":"COUNSELING SERVICES","sectionTitle":"Comprehensive Counseling Services","sectionSupport":"Professional, compassionate counseling integrated within our rehabilitation programs for patient and family wellbeing.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Individual Patient Counseling","description":"One-to-one counseling sessions addressing the emotional impact of sudden disability, the grief of lost function and independence, adjustment to changed life roles and relationships, motivation and engagement in rehabilitation, fear of the future, and spiritual and existential questions that arise in serious illness. Person-centered, solution-focused, and CBT approaches used flexibly to meet each patient's needs."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Family & Caregiver Counseling","description":"Structured family sessions facilitated by our counselors: understanding the patient's diagnosis and what to realistically expect from recovery; managing changed family dynamics, roles, and responsibilities; communication strategies that support the patient's autonomy and dignity; financial planning implications of long-term care; and managing sibling and extended family relationships when a family member has serious illness."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Sattvavajaya (Ayurvedic Mind Counseling)","description":"Ayurveda's Sattvavajaya Chikitsa — psychological healing through self-knowledge, positive thinking, and spiritual alignment — complements modern counseling with ancient wisdom. Practices including Svadhyaya (self-reflection), positive affirmation (Mantra recitation), and guidance on Ayurvedic lifestyle for mental wellbeing (Dinacharya, Sadvritta) provide a culturally resonant framework for psychological healing alongside modern counseling."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Group Support & Peer Support Programs","description":"Structured therapeutic support groups for stroke survivors, brain injury patients, spinal cord injury patients, and caregivers — providing peer connection, shared experience, mutual support, and practical advice from those who truly understand the challenges. Group therapy reduces isolation, builds community, and accelerates the adjustment process through shared narrative and collective wisdom."}]},"technologies":{"sectionLabel":"COUNSELING APPROACHES","sectionTitle":"Counseling Approaches & Support Tools","sectionSupport":"Evidence-based counseling techniques integrated with Ayurvedic psychological approaches for complete emotional support.","cards":[{"icon":"heart-handshake","title":"Person-Centered Counseling","description":"Carl Rogers-based person-centered approach providing unconditional positive regard, empathic understanding, and genuine therapeutic presence — the foundation of effective counseling."},{"icon":"brain","title":"CBT & Solution-Focused Approaches","description":"Cognitive Behavioral Therapy for depression and anxiety; Solution-Focused Brief Therapy for practical problem-solving; Motivational Interviewing for rehabilitation engagement."},{"icon":"leaf","title":"Sattvavajaya Chikitsa","description":"Ayurvedic psychological healing through self-knowledge, Mantra therapy, and positive lifestyle guidance — providing a culturally resonant complement to Western counseling approaches."},{"icon":"users","title":"Peer Support Groups","description":"Facilitated peer support groups for stroke, SCI, TBI, and caregiver populations — reducing isolation and accelerating psychological adjustment through shared experience."},{"icon":"heart","title":"Spiritual & Existential Support","description":"Sensitive support for the spiritual and existential questions that arise in serious illness — working with the patient's own faith tradition and spiritual framework to find meaning, hope, and peace."}]},"faq":{"sectionSupport":"Find answers to key details about the Counseling program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Counseling combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","Lhcaf6jsYt4dMJtqNYQnQ",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
