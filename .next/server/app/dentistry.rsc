n":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["dentistry",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","dentistry","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"dentistry","sidebarId":"dentistry","metaTitle":"Dentistry | Ayurgreen Hospital","metaDescription":"Dedicated premium dental care, hygiene maintenance, and corrective dentistry procedures in a comfortable clinic setting.","canonicalPath":"/dentistry","hero":{"bannerImage":"Assets/rehab/th_panchakarma.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Dentistry","subtitle":"Dedicated premium dental care, hygiene maintenance, and corrective dentistry procedures in a comfortable clinic setting."},"overview":{"sectionLabel":"OVERVIEW","title":"Dentistry: Oral Health as a Foundation of Overall Wellness","paragraphs":["Oral health is inseparable from overall health. Dental problems — from tooth decay and gum disease to dental pain and oral infections — not only cause local suffering but contribute to systemic inflammation, impair nutrition through difficulty eating, and significantly affect confidence, social interaction, and quality of life.","At Ayurgreen Hospital, our Dentistry Department provides comprehensive dental care within the holistic, integrated hospital environment. Dental care is particularly important for our rehabilitation population — poor oral hygiene increases the risk of aspiration pneumonia in dysphagic stroke patients; dental pain can disrupt concentration and rehabilitation engagement; and nutritional needs may be compromised if dental problems make eating painful or difficult.","Our dental team provides expert care from routine preventive dentistry through to complex restorations and oral surgery, in a calm, patient-centered environment that accommodates the special needs of our medically complex rehabilitation patients."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Dentistry at Ayurgreen Hospital"},"conditions":{"sectionLabel":"DENTAL SERVICES","sectionTitle":"Dental Conditions & Services We Provide","sectionSupport":"Comprehensive dental care for the general public and the special dental needs of our rehabilitation patients.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Preventive & Restorative Dentistry","description":"Routine check-ups, professional cleaning (scaling and polishing), cavity detection, composite fillings, and crown restorations — comprehensive preventive and restorative dental care for long-term oral health."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Oral Surgery & Extractions","description":"Expert tooth extractions (including impacted wisdom teeth), minor oral surgery, and management of dental infections — performed safely with awareness of each patient's medical conditions and medications."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Prosthetics & Dental Implants","description":"Dental implants, dentures, bridges, and crowns for tooth replacement — restoring the ability to eat comfortably, speak clearly, and smile with confidence after tooth loss."}]},"treatments":{"sectionLabel":"DENTAL SERVICES","sectionTitle":"Comprehensive Dental Care","sectionSupport":"Expert, patient-centered dental care integrated with our holistic hospital environment.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Preventive Dental Care & Oral Hygiene","description":"Comprehensive preventive dentistry: professional scaling and polishing, fluoride treatments, dental sealants for children, caries risk assessment, customized oral hygiene instruction, and nutritional counseling for dental health. For our rehabilitation patients — particular emphasis on oral hygiene protocols for those with dysphagia and reduced saliva production, to prevent aspiration pneumonia."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Restorative & Cosmetic Dentistry","description":"Tooth-colored composite fillings, porcelain crowns and bridges, dental inlays and onlays, and ceramic veneers — restoring the function, strength, and aesthetics of damaged teeth. Digital X-ray and intraoral cameras for precise diagnosis. All restorative materials are carefully selected for biocompatibility."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Oral Health Integration","description":"Ayurveda's Dantadhavana (tooth care) and Gandusha (oil pulling) practices complement modern dental care with powerful antibacterial, anti-inflammatory, and oral microbiome-balancing effects. Arimedadi Tailam (Ayurvedic oil pulling preparation), Triphala mouthwash for gum health, and herbal tooth powders are integrated with conventional dental treatment for comprehensive oral health."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Dental Implants & Prosthetic Dentistry","description":"Titanium dental implants providing the most natural and functional replacement for missing teeth — preserving bone, enabling normal biting and chewing, and restoring confidence. Implant-supported dentures and bridges for those with multiple missing teeth. Conventional full and partial dentures with high-quality materials and optimal fit for comfort and function."}]},"technologies":{"sectionLabel":"DENTAL TECHNOLOGY","sectionTitle":"Advanced Dental Technology","sectionSupport":"Modern dental technology for precise diagnosis, comfortable treatment, and excellent aesthetic outcomes.","cards":[{"icon":"smile","title":"Digital Dental X-Ray","description":"Low-radiation digital dental radiography providing high-resolution images for precise diagnosis of cavities, bone loss, and pathology — with dramatically less radiation than conventional X-rays."},{"icon":"activity","title":"Intraoral Camera","description":"High-magnification intraoral cameras allowing patients to see exactly what the dentist sees — improving communication, understanding, and informed consent for all dental procedures."},{"icon":"zap","title":"Laser Dentistry","description":"Dental laser for painless gum therapy, cavity preparation with minimal drilling, teeth whitening, and minor oral surgery — improving patient comfort and reducing treatment time."},{"icon":"leaf","title":"Ayurvedic Oral Hygiene Integration","description":"Arimedadi Tailam oil pulling, Triphala mouthwash, and herbal dental powders complementing conventional dental care for comprehensive oral health and microbiome balance."},{"icon":"shield-plus","title":"Medically Complex Dental Care","description":"Expert dental care for patients on anticoagulants, antiplatelet agents, bisphosphonates, and immunosuppressants — safely managing the dental needs of our medically complex rehabilitation patients."}]},"faq":{"sectionSupport":"Find answers to key details about the Dentistry program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Dentistry combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","d7eXc6BsyIaehWix0jrnH",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
