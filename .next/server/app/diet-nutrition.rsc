"$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["diet-nutrition",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","diet-nutrition","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"diet-nutrition","sidebarId":"diet-nutrition","metaTitle":"Diet & Nutrition | Ayurgreen Hospital","metaDescription":"Custom GMP-prepared healing foods mapped directly to metabolic states and clinical digestive requirements.","canonicalPath":"/diet-nutrition","hero":{"bannerImage":"Assets/rehab/th_panchakarma.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Diet & Nutrition","subtitle":"Custom GMP-prepared healing foods mapped directly to metabolic states and clinical digestive requirements."},"overview":{"sectionLabel":"OVERVIEW","title":"Diet & Nutrition: Fueling Recovery, Optimizing Health","paragraphs":["Nutrition is the foundation of all healing. Every cellular repair process, every neurological recovery mechanism, every immune response — they all depend on adequate, appropriate nutrition. In the context of neurological and physical rehabilitation, optimal nutrition is not just supportive — it is a primary therapeutic intervention.","At Ayurgreen Hospital, our Dietetics and Nutrition Department provides expert, individualized nutritional care for all patients. Our registered dietitians work as integral members of the rehabilitation team, understanding that a patient who is malnourished, hyperglycemic, or nutritionally deficient cannot achieve their maximum rehabilitation potential.","Our approach uniquely combines modern evidence-based nutritional science with Ayurvedic dietary principles (Pathya-Apathya) — creating nutritional plans that are not only clinically precise but also culturally appropriate, palatable, and sustainable for long-term health after discharge."],"image":"Assets/rehab/th_ayurveda.webp","imageAlt":"Diet & Nutrition at Ayurgreen Hospital"},"conditions":{"sectionLabel":"NUTRITION SERVICES","sectionTitle":"Nutritional Support We Provide","sectionSupport":"Comprehensive, individualized nutritional care for all rehabilitation patients and community health goals.","cards":[{"image":"Assets/rehab/th_ayurveda.webp","title":"Rehabilitation Nutrition","description":"Optimized nutrition for neurological and physical rehabilitation — supporting neuroplasticity with brain-healthy nutrients (Omega-3, antioxidants), providing adequate protein for muscle recovery, and managing swallowing difficulties with texture-modified diets."},{"image":"Assets/rehab/prog_stroke.webp","title":"Therapeutic Medical Diets","description":"Specialized therapeutic diets for medical conditions: diabetic diet, renal diet, cardiac diet (low sodium, low fat), ketogenic diet for epilepsy, high-protein diet for wound healing, anti-inflammatory diet for arthritis and autoimmune conditions."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Weight Management & Metabolic Nutrition","description":"Evidence-based nutritional programs for weight loss, muscle gain, sports performance, and metabolic syndrome management — combining caloric precision with Ayurvedic dietary wisdom."}]},"treatments":{"sectionLabel":"NUTRITION SERVICES","sectionTitle":"Comprehensive Dietetics & Nutrition Services","sectionSupport":"Expert, individualized nutritional care integrating modern nutritional science with Ayurvedic dietary wisdom.","steps":[{"image":"Assets/rehab/th_ayurveda.webp","title":"Comprehensive Nutritional Assessment","description":"Detailed nutritional assessment for every admitted patient: anthropometric measurements (weight, height, BMI, waist circumference), body composition analysis, dietary history assessment, biochemical nutritional markers (albumin, prealbumin, micronutrient levels), dysphagia screening for neurological patients, and identification of malnutrition risk using validated tools (MNA, SGA)."},{"image":"Assets/rehab/prog_stroke.webp","title":"Neurological Rehabilitation Dietetics","description":"Specialized nutritional management for neurological rehabilitation: high-protein nutrition supporting muscle rebuilding during intensive physiotherapy; brain-healthy micronutrients (B12, folate, Omega-3, antioxidants) supporting neuroplasticity; diabetic nutrition for the high proportion of diabetic stroke patients; dysphagia diet management (IDDSI texture-modified foods); and enteral and parenteral nutrition for patients unable to eat orally."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Dietary Medicine (Pathya-Apathya)","description":"Ayurvedic dietary principles form a sophisticated nutritional science: Pathya (appropriate) and Apathya (inappropriate) foods are individually prescribed based on each patient's Prakriti (constitution), current Vikriti (imbalance), and condition. Specific foods that support stroke recovery (warm, easy-to-digest foods, ghee in moderation), reduce Vata (neurological diseases), or pacify Kapha (obesity, metabolic disease) are incorporated into practical, culturally appropriate meal plans."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Clinical & Enteral Nutrition Support","description":"Comprehensive clinical nutrition support for complex rehabilitation patients: nasogastric and PEG tube feeding management for patients with severe dysphagia or reduced consciousness; parenteral nutrition for patients unable to tolerate enteral feeds; transition feeding protocols supporting the move from tube feeding to oral nutrition; and specialized nutrition for wound healing, pressure sore management, and post-surgical recovery."}]},"technologies":{"sectionLabel":"NUTRITION CAPABILITIES","sectionTitle":"Advanced Dietetics & Nutrition Technology","sectionSupport":"Evidence-based nutritional assessment and intervention for optimal rehabilitation and health outcomes.","cards":[{"icon":"utensils","title":"Metabolic Rate Assessment","description":"Resting metabolic rate measurement enabling precisely individualized caloric prescriptions — eliminating guesswork and ensuring nutrition plans are physiologically accurate."},{"icon":"activity","title":"DEXA Body Composition","description":"Dual-energy X-ray absorptiometry measuring fat mass, lean mass, and bone density — the most accurate method for monitoring nutritional rehabilitation progress."},{"icon":"leaf","title":"Ayurvedic Dietary Consultation","description":"Individualized Pathya-Apathya dietary prescriptions combining Ayurvedic constitutional analysis with modern nutritional science for culturally appropriate, clinically optimal meal planning."},{"icon":"droplet","title":"Dysphagia Diet Management","description":"IDDSI-compliant texture-modified food preparation and liquid thickening for all levels of dysphagia — ensuring safe oral nutrition for neurological patients at every stage of swallowing recovery."},{"icon":"shield-plus","title":"Enteral Nutrition Management","description":"Expert management of nasogastric, PEG, and jejunal tube feeding including formula selection, rate titration, complication management, and transition feeding protocols."}]},"faq":{"sectionSupport":"Find answers to key details about the Diet & Nutrition program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Diet & Nutrition combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","HYfDuoZW-ZxLoitUkdaYY",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
