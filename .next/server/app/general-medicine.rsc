"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["general-medicine",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","general-medicine","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"general-medicine","sidebarId":"general-medicine","metaTitle":"General Medicine | Ayurgreen Hospital","metaDescription":"Managing general metabolic health, blood pressure, diabetes, and clinical balance alongside active daily rehabilitation.","canonicalPath":"/general-medicine","hero":{"bannerImage":"Assets/rehab/th_physiotherapy.webp","label":"Modern Integrations","breadcrumbCategory":"Modern Integrations","title":"General Medicine","subtitle":"Managing general metabolic health, blood pressure, diabetes, and clinical balance alongside active daily rehabilitation."},"overview":{"sectionLabel":"OVERVIEW","title":"General Medicine: Comprehensive Internal Medicine Care","paragraphs":["General Medicine, or Internal Medicine, is the bedrock of comprehensive hospital care. It provides expert diagnosis and management of a vast spectrum of medical conditions — from common infections and chronic diseases to complex multi-system disorders that require a discerning clinical mind to unravel.","At Ayurgreen Hospital, our General Medicine team serves a critical dual function: managing the general health of all patients within our complex rehabilitation population, and providing specialized medical services to all patients and their families in the local community.","Our physicians are experts in managing the medical complexities that arise in rehabilitation patients — such as preventing secondary strokes, managing diabetes in spinal cord injury patients, controlling hypertension in brain injury survivors, and treating infections in immune-compromised patients. This in-house medical expertise ensures that our rehabilitation patients are always medically safe and stable, even as they undergo intensive physical recovery."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"General Medicine at Ayurgreen Hospital"},"conditions":{"sectionLabel":"WHAT WE TREAT","sectionTitle":"Medical Conditions We Manage","sectionSupport":"Expert clinical management for acute illnesses, chronic diseases, and the complex medical needs of our rehabilitation population.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Acute & Infectious Diseases","description":"Expert management of acute febrile illnesses, respiratory tract infections, urinary tract infections, gastrointestinal disorders, and other acute medical presentations requiring prompt, expert diagnosis and treatment."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Chronic Disease Management","description":"Comprehensive, long-term management of diabetes mellitus, hypertension, thyroid disorders, chronic kidney disease, liver disease, and autoimmune conditions. Dedicated clinics ensure optimal control and prevention of organ damage."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Rehabilitation Medical Support","description":"Specialized internal medical care for rehabilitation inpatients, including management of post-stroke complications, autonomic dysreflexia in spinal cord injury, aspiration pneumonia in dysphagia patients, and pressure sore prevention and care."}]},"treatments":{"sectionLabel":"CLINICAL SERVICES","sectionTitle":"Comprehensive General Medicine Services","sectionSupport":"Expert internal medical care delivered by experienced physicians in close collaboration with our specialist rehabilitation team.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Specialized Chronic Disease Clinics","description":"Dedicated clinics for Diabetes (including insulin pump management), Hypertension (with 24-hour ambulatory monitoring), Thyroid, and Metabolic Syndrome. Our physicians use the latest evidence-based protocols to achieve optimal medical control, which is essential for maximizing rehabilitation outcomes."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Preventive Medicine & Health Screening","description":"Comprehensive health check packages for all age groups covering cardiac risk assessment, cancer screening, diabetes screening, pulmonary function testing, and metabolic profiling. Early detection is the most powerful tool in disease management."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Evidence-Based Ayurvedic Integration","description":"Our general physicians collaborate with Ayurvedic physicians to integrate evidence-based herbal medicines and lifestyle protocols for chronic disease management. Ayurvedic interventions for diabetes (Diabetes management protocols), hypertension, and metabolic syndrome are prescribed carefully alongside and in harmony with conventional medical treatments."},{"image":"Assets/rehab/th_robotic.webp","title":"Intensive Rehabilitation Medical Support","description":"Daily medical ward rounds for all rehabilitation inpatients by our internal medicine team. Rapid intervention for any medical complications arising during rehabilitation — including DVT prevention, nutrition management, wound care, and infection control — ensuring patients can safely continue their rehabilitation programs without interruption."}]},"technologies":{"sectionLabel":"DIAGNOSTIC CAPABILITIES","sectionTitle":"Advanced Medical Diagnostics","sectionSupport":"Comprehensive diagnostic capabilities for rapid, accurate clinical decision-making.","cards":[{"icon":"activity","title":"Advanced Laboratory Services","description":"Full in-house pathology laboratory for rapid blood analysis, urine studies, microbiology, and specialized tests — ensuring fast, accurate diagnostic results."},{"icon":"heart","title":"ECG & Holter Monitoring","description":"12-lead ECG for acute cardiac assessment, 24-hour Holter monitoring for cardiac rhythm disorders, and 24-hour ambulatory blood pressure monitoring for hypertension management."},{"icon":"wind","title":"Pulmonary Function Testing","description":"Spirometry and comprehensive pulmonary function tests to diagnose COPD, asthma, and respiratory complications common in rehabilitation patients."},{"icon":"leaf","title":"Ayurvedic Medicine Integration","description":"Evidence-based Ayurvedic formulations for diabetes, hypertension, and metabolic syndrome management, prescribed in collaboration with internal medicine physicians."},{"icon":"syringe","title":"Infusion & IV Therapy Suite","description":"Dedicated infusion center for IV antibiotics, IV nutritional support, and specialized infusion therapies for rehabilitation patients requiring parenteral treatment."}]},"faq":{"sectionSupport":"Find answers to key details about the General Medicine program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for General Medicine combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","oxaQKURruUnqLO-Mz3FGt",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
