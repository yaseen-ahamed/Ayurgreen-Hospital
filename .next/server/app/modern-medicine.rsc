essHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["modern-medicine",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","modern-medicine","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"modern-medicine","sidebarId":"modern-medicine","metaTitle":"Modern Medicine | Ayurgreen Hospital","metaDescription":"Coordinating clinical diagnostics, primary care, emergency cover, and medical treatments alongside rehabilitation protocols.","canonicalPath":"/modern-medicine","hero":{"bannerImage":"Assets/rehab/th_panchakarma.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Modern Medicine","subtitle":"Coordinating clinical diagnostics, primary care, emergency cover, and medical treatments alongside rehabilitation protocols."},"overview":{"sectionLabel":"OVERVIEW","title":"Modern Medicine: Evidence-Based Healthcare at Ayurgreen","paragraphs":["Modern Medicine — evidence-based allopathic medicine grounded in scientific research and clinical trials — is the foundation of safe, effective healthcare for acute and complex conditions. At Ayurgreen Hospital, modern medicine and Ayurveda are not in competition — they are complementary partners in comprehensive patient care.","Our Modern Medicine Department provides all the essential medical services needed to safely support the complex, medically vulnerable patients in our rehabilitation programs. From managing post-stroke complications and monitoring cardiac function to treating infections and managing metabolic diseases, our modern medicine team ensures that every patient is medically stable and safe to participate in intensive rehabilitation.","The hallmark of Ayurgreen's modern medicine approach is its seamless integration with our Ayurvedic and rehabilitation services — our physicians, neurologists, cardiologists, and general practitioners work daily alongside Ayurvedic physicians, physiotherapists, and robotics engineers in one unified, multidisciplinary clinical team."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Modern Medicine at Ayurgreen Hospital"},"conditions":{"sectionLabel":"MODERN MEDICINE SERVICES","sectionTitle":"Medical Specialties We Provide","sectionSupport":"Comprehensive modern medical services supporting our rehabilitation population and serving the wider community.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Acute & Emergency Medical Care","description":"Expert management of acute medical emergencies including stroke (acute assessment and stabilization), seizures, cardiac events, respiratory failure, and acute infections arising during the rehabilitation period."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Specialist Medical Consultations","description":"A full panel of medical specialists — neurologists, cardiologists, urologists, pulmonologists, gastroenterologists, and endocrinologists — providing expert consultation for complex medical needs within the rehabilitation context."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Preventive & Health Promotion","description":"Comprehensive health screening packages, vaccination programs, cancer screening, cardiovascular risk assessment, and lifestyle medicine — evidence-based preventive healthcare for community patients."}]},"treatments":{"sectionLabel":"MEDICAL SERVICES","sectionTitle":"Comprehensive Modern Medical Services","sectionSupport":"The full spectrum of modern medical care integrated with Ayurveda and rehabilitation for complete patient health.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Rehabilitation Medicine & Physiatry","description":"Physiatrists (rehabilitation medicine specialists) provide the medical leadership of our rehabilitation programs — prescribing comprehensive rehabilitation protocols, managing spasticity with Botox and baclofen, overseeing secondary stroke prevention, and coordinating all medical aspects of the rehabilitation journey. This specialist medical oversight ensures all rehabilitation activities are safe, evidence-based, and medically optimized."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Secondary Prevention & Chronic Disease Management","description":"Rigorous secondary prevention protocols for our neurological patients — the most critical medical intervention to prevent a second stroke or TBI. Optimal blood pressure control, anticoagulation management for atrial fibrillation, lipid-lowering therapy, diabetes management, and lifestyle counseling. Our general physicians manage all chronic comorbidities alongside the specialist rehabilitation program."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Integrative Medicine (Modern + Ayurveda)","description":"At Ayurgreen, our modern medicine physicians actively collaborate with Ayurvedic physicians to create integrated, evidence-based care plans where both systems contribute their unique strengths. Modern medications provide rapid, precise pharmacological effects; Ayurvedic therapies provide deep, systemic healing and reduce side effects. This genuine integrative medicine approach is our most distinctive clinical innovation."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Diagnostic & Laboratory Services","description":"Comprehensive in-house diagnostic capabilities: clinical pathology laboratory for blood, urine, and microbiological studies; radiology services (X-ray, ultrasound, and CT scan interpretation); ECG, EEG, EMG/NCS electrophysiology; and on-site pharmacy — providing all the diagnostic tools needed for comprehensive medical management within one hospital campus."}]},"technologies":{"sectionLabel":"MODERN MEDICINE CAPABILITIES","sectionTitle":"Advanced Medical Technology & Integration","sectionSupport":"Comprehensive modern medical capabilities seamlessly integrated with Ayurvedic and rehabilitation services.","cards":[{"icon":"activity","title":"Clinical Laboratory","description":"In-house clinical pathology laboratory providing rapid blood, urine, microbiology, and coagulation studies — essential for safe medical management of complex rehabilitation patients."},{"icon":"heart","title":"Cardiac Monitoring","description":"12-lead ECG, Holter monitoring, and continuous bedside cardiac telemetry for safe monitoring of cardiovascular status during intensive rehabilitation programs."},{"icon":"brain","title":"Electrophysiology Suite","description":"EMG/Nerve Conduction Studies, EEG, and evoked potential studies for neurological diagnosis and monitoring — performed and interpreted by our specialist neurology team."},{"icon":"leaf","title":"Integrative Pharmacy","description":"In-house pharmacy stocking both modern pharmaceutical preparations and standardized, GMP-certified Ayurvedic medicines — the physical embodiment of our integrative medicine philosophy."},{"icon":"pill","title":"Polypharmacy Management","description":"Expert medication review and management for complex rehabilitation patients on multiple medications — preventing adverse drug interactions and optimizing pharmaceutical therapy for recovery."}]},"faq":{"sectionSupport":"Find answers to key details about the Modern Medicine program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Modern Medicine combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","7LaJnC_Hg-MA5YOcprnTD",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
