gin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["motor-neuron-diseases",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","motor-neuron-diseases","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"motor-neuron-diseases","sidebarId":"mnd","metaTitle":"Motor Neuron Diseases Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Providing neurological nourishment, muscle spasm control, and custom exercises to maintain function and manage progression.","canonicalPath":"/motor-neuron-diseases","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Motor Neuron Disease.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Motor Neuron Diseases","subtitle":"Providing neurological nourishment, muscle spasm control, and custom exercises to maintain function and manage progression."},"overview":{"sectionLabel":"OVERVIEW","title":"Motor Neuron Disease Management: Preserving Dignity & Function","paragraphs":["Motor Neuron Diseases (MND) — including Amyotrophic Lateral Sclerosis (ALS), Progressive Muscular Atrophy (PMA), and Primary Lateral Sclerosis (PLS) — are conditions where the motor neurons that control voluntary muscle movements progressively degenerate. They are among the most challenging conditions in all of medicine.","At Ayurgreen Hospital, we provide a specialized, compassionate, and comprehensive MND management program. While no cure yet exists for most MNDs, the right multidisciplinary management can profoundly slow functional decline, extend independence, preserve communication and swallowing, maximize quality of life, and support both patient and family.","Our integrated approach uniquely combines modern neuroprotective medicine, respiratory therapy, speech and swallowing management, physiotherapy, occupational therapy, and authentic Ayurvedic neuroprotective therapies — creating the most comprehensive MND care program available."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Motor Neuron Diseases at Ayurgreen Hospital"},"conditions":{"sectionLabel":"CONDITIONS WE MANAGE","sectionTitle":"Motor Neuron Diseases We Specialize In","sectionSupport":"Expert management for all motor neuron diseases, with a focus on maximizing function and quality of life.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Amyotrophic Lateral Sclerosis (ALS/MND)","description":"The most common MND, affecting both upper and lower motor neurons. Our comprehensive ALS care program includes Riluzole/Edaravone therapy, aggressive respiratory management, speech and swallowing preservation, and Ayurvedic neuroprotective therapies."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Primary Lateral Sclerosis & Progressive Muscular Atrophy","description":"PLS (upper motor neuron only) and PMA (lower motor neuron only) — conditions with slower progression than ALS, where careful physiotherapy and Ayurvedic management can significantly slow functional decline."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Kennedy Disease & Hereditary MND","description":"Spinal and bulbar muscular atrophy (Kennedy disease) and hereditary spastic paraplegia — genetic MNDs requiring specialized genetic counseling, physiotherapy, and supportive Ayurvedic care."}]},"treatments":{"sectionLabel":"MANAGEMENT APPROACH","sectionTitle":"Comprehensive MND Management Services","sectionSupport":"Multidisciplinary, integrated management targeting all aspects of function, communication, breathing, and quality of life.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Physiotherapy & Physical Function Preservation","description":"Carefully calibrated exercise programs that maintain strength and function in unaffected muscles without overworking compromised neurons. Passive ranging, gentle strengthening, stretching, and posture management prevent contractures and maintain comfort. As weakness progresses, our therapists adapt programs to preserve independence using assistive devices and adaptive strategies."},{"image":"Assets/rehab/th_speech.webp","title":"Speech, Swallowing & Communication Preservation","description":"Proactive speech therapy to preserve intelligibility as dysarthria progresses. Dysphagia management with texture modification and swallowing strategies to prevent aspiration. Augmentative and Alternative Communication (AAC) — from low-tech letter boards to high-tech eye-gaze computer systems — planned and implemented early to maintain communication throughout the disease course."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Neuroprotective Therapies","description":"Kerala Ayurveda offers specific neuroprotective approaches for MND: Medhya Rasayana formulations (Brahmi, Ashwagandha, Shatavari) with emerging evidence for neuroprotection and anti-inflammatory effects; Abhyanga with nerve-nourishing medicated oils to maintain muscle health and reduce spasticity; Shirodhara and Yoga for significant reduction of anxiety, depression, and sleep disturbance."},{"image":"Assets/rehab/prog_stroke.webp","title":"Respiratory Management & Ventilatory Support","description":"Respiratory failure is the most critical life-limiting issue in ALS. Our respiratory therapists perform regular respiratory function monitoring (FVC, MIP, MEP), implement non-invasive ventilation (BiPAP) when needed, provide respiratory physiotherapy, and work with patients and families on advance care planning and decision-making about ventilatory support."}]},"technologies":{"sectionLabel":"MND CARE TECHNOLOGY","sectionTitle":"Advanced Technology for MND Management","sectionSupport":"Comprehensive technology for function preservation, communication, respiratory support, and quality of life.","cards":[{"icon":"activity","title":"Respiratory Monitoring (FVC, MIP, MEP)","description":"Regular pulmonary function monitoring to track respiratory muscle decline and time the initiation of non-invasive ventilation at the optimal point to maximize benefit."},{"icon":"mic","title":"AAC Communication Systems","description":"Eye-gaze communication devices, voice banking technology, and speech-generating devices — planned and implemented early to ensure patients maintain communication throughout the disease course."},{"icon":"wind","title":"Non-Invasive Ventilation (BiPAP)","description":"Timely initiation of BiPAP ventilation to extend life, reduce breathlessness, and maintain quality of life as respiratory muscles weaken — prescribed and monitored by our respiratory team."},{"icon":"leaf","title":"Medhya Rasayana Neuroprotection","description":"Evidence-informed Ayurvedic neuroprotective formulations (Brahmi, Ashwagandha, Shatavari) and nerve-nourishing oil therapies to slow functional decline and maintain quality of life."},{"icon":"heart-handshake","title":"Palliative & Psychological Support","description":"Integrated psychological support, counseling, and palliative care planning throughout the MND journey, for both patients and families, ensuring dignity, comfort, and quality of life."}]},"faq":{"sectionSupport":"Find answers to key details about the Motor Neuron Diseases program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Motor Neuron Diseases combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","PGctP4UGVHKY_bquZ2v3i",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
