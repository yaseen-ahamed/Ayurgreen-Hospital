8:T67b,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/muscular-dystrophy#webpage","url":"https://ayurgreenhospital.com/muscular-dystrophy","name":"Muscular Dystrophy Rehabilitation & Care | Ayurgreen Hospital","description":"Providing muscular nutrition, maintaining joint range, and custom gentle exercises to slow functional muscle decline.","about":{"@type":"MedicalSpecialty","name":"Integrated Muscular Dystrophy Rehabilitation"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/muscular-dystrophy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Specialities","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Muscular Dystrophy","item":"https://ayurgreenhospital.com/muscular-dystrophy"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/muscular-dystrophy#service","name":"Muscular Dystrophy Rehabilitation","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Providing muscular nutrition, maintaining joint range, and custom gentle exercises to slow functional muscle decline."}]}0:{"P":null,"b":"LiUuSPa93huxu4xcSB3P5","p":"","c":["","muscular-dystrophy"],"i":false,"f":[[["",{"children":["muscular-dystrophy",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["muscular-dystrophy",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","muscular-dystrophy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"muscular-dystrophy","sidebarId":"muscular-dystrophy","metaTitle":"Muscular Dystrophy Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Providing muscular nutrition, maintaining joint range, and custom gentle exercises to slow functional muscle decline.","canonicalPath":"/muscular-dystrophy","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Muscular Dystrophy.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Muscular Dystrophy","subtitle":"Providing muscular nutrition, maintaining joint range, and custom gentle exercises to slow functional muscle decline."},"overview":{"sectionLabel":"OVERVIEW","title":"Muscular Dystrophy Rehabilitation: Maximizing Function & Quality of Life","paragraphs":["Muscular Dystrophies are a group of inherited genetic disorders characterized by progressive weakness and degeneration of the skeletal muscles. Duchenne MD (DMD), Becker MD, Limb-Girdle MD, Facioscapulohumeral MD, and Myotonic Dystrophy are among the most common — each with distinct patterns of weakness and progression.","At Ayurgreen Hospital, our Muscular Dystrophy Rehabilitation Program provides comprehensive, compassionate, and expert care for patients of all ages with all types of MD. While we cannot yet stop the underlying genetic disease process, the right rehabilitation program can dramatically slow functional decline, extend independent ambulation, prevent complications, and significantly improve quality of life.","Our program uniquely integrates modern gene therapy consultation and medical management with specialized physiotherapy, respiratory management, and Ayurvedic muscle-nourishing therapies — creating the most comprehensive MD care available."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Muscular Dystrophy at Ayurgreen Hospital"},"conditions":{"sectionLabel":"MD TYPES WE MANAGE","sectionTitle":"Muscular Dystrophies We Specialize In","sectionSupport":"Expert care for all types and stages of hereditary muscular dystrophy in both children and adults.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Duchenne & Becker Muscular Dystrophy","description":"The most common and most severe forms of MD, primarily affecting boys. Our program uses corticosteroid therapy, proactive respiratory management, cardiac monitoring, and carefully calibrated physiotherapy to extend ambulation and quality of life."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Limb-Girdle Muscular Dystrophy","description":"Progressive weakness of the hip and shoulder girdle muscles. Targeted strengthening programs, adaptive equipment, and Ayurvedic muscle therapies to maintain independence as long as possible."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"FSH & Myotonic Dystrophy","description":"Facioscapulohumeral MD (affecting face and shoulder) and Myotonic Dystrophy (with characteristic myotonia, cardiac, and respiratory complications) — each requiring specialized management approaches."}]},"treatments":{"sectionLabel":"MD REHABILITATION","sectionTitle":"Comprehensive Muscular Dystrophy Care","sectionSupport":"Multi-system management extending function, preventing complications, and maximizing quality of life in muscular dystrophy.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Specialized MD Physiotherapy","description":"Sub-maximal, carefully calibrated exercise programs to maintain muscle strength without the eccentric exercise that damages dystrophic muscle fibers. Aquatic therapy provides excellent exercise with minimal muscle damage. Stretching programs prevent contractures — particularly important in Achilles tendon and hip flexors. Gait training and orthotic prescription extend the period of ambulation."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Muscle-Nourishing Therapies","description":"Kerala Ayurveda offers uniquely powerful muscle-building therapies: Njavara Kizhi (medicated rice bundle massage) has the strongest muscle-building properties of any Ayurvedic treatment; Bala Ashwagandha tailam (oil massage) with muscle-nourishing medicated oils; and Balya (strengthening) Rasayana formulations — Ashwagandha, Shatavari, Bala — which are being investigated for their molecular effects on muscle protein synthesis."},{"image":"Assets/rehab/th_robotic.webp","title":"Robotic-Assisted Exercise","description":"For MD patients with significant weakness, robotic assistance enables meaningful exercise without overexertion. Body-weight supported gait training on the G-EO extends ambulation and maintains muscle health in lower limb MD. Armotion provides assisted arm exercise for patients with shoulder girdle weakness."},{"image":"Assets/rehab/prog_stroke.webp","title":"Respiratory & Cardiac Management","description":"Many MDs (DMD, Myotonic, EDMD) have significant cardiac and respiratory complications. We provide regular cardiac monitoring (ECG, Echo), respiratory function monitoring (FVC, MIP), proactive non-invasive ventilation initiation, and Holter monitoring for arrhythmias — preventing life-threatening complications and extending life expectancy."}]},"technologies":{"sectionLabel":"MD CARE TECHNOLOGY","sectionTitle":"Advanced Technology for Muscular Dystrophy Care","sectionSupport":"Comprehensive technology for function preservation, complication prevention, and quality of life in muscular dystrophy.","cards":[{"icon":"waves","title":"Hydrotherapy (AquaCiser III)","description":"Water-based exercise that minimizes eccentric muscle loading — the most muscle-damaging exercise type in MD — while providing excellent cardiovascular and strength training."},{"icon":"leaf","title":"Njavara Kizhi & Balya Rasayana","description":"Powerful Ayurvedic muscle-nourishing therapies with rice bundles and strengthening herbal formulations (Ashwagandha, Bala, Shatavari) supporting muscle protein synthesis and reducing fatigue."},{"icon":"wind","title":"Respiratory Monitoring & NIV","description":"Serial FVC and respiratory muscle strength monitoring with timely BiPAP initiation to extend life and prevent respiratory failure in DMD and Myotonic Dystrophy."},{"icon":"heart","title":"Cardiac Monitoring","description":"Regular ECG, echocardiography, and Holter monitoring for DMD and Myotonic Dystrophy patients — detecting and managing cardiomyopathy and arrhythmias early."},{"icon":"bot","title":"Robotic-Assisted Gait Training","description":"Body-weight supported walking training using the G-EO system to extend ambulation period and maintain lower limb muscle health in limb-girdle and Duchenne MD."}]},"faq":{"sectionSupport":"Find answers to key details about the Muscular Dystrophy program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Muscular Dystrophy combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","wNjG4Xi69LjE-0c7f7Ki7",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
