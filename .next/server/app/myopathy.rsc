8:T623,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/myopathy#webpage","url":"https://ayurgreenhospital.com/myopathy","name":"Myopathy Rehabilitation & Care | Ayurgreen Hospital","description":"Nourishing muscle tissue, boosting strength, and prescribing safe mobility protocols to manage active muscle weakness.","about":{"@type":"MedicalSpecialty","name":"Integrated Myopathy Rehabilitation"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/myopathy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Specialities","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Myopathy","item":"https://ayurgreenhospital.com/myopathy"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/myopathy#service","name":"Myopathy Rehabilitation","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Nourishing muscle tissue, boosting strength, and prescribing safe mobility protocols to manage active muscle weakness."}]}0:{"P":null,"b":"LiUuSPa93huxu4xcSB3P5","p":"","c":["","myopathy"],"i":false,"f":[[["",{"children":["myopathy",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["myopathy",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","myopathy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"myopathy","sidebarId":"myopathy","metaTitle":"Myopathy Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Nourishing muscle tissue, boosting strength, and prescribing safe mobility protocols to manage active muscle weakness.","canonicalPath":"/myopathy","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Myopathy.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Myopathy","subtitle":"Nourishing muscle tissue, boosting strength, and prescribing safe mobility protocols to manage active muscle weakness."},"overview":{"sectionLabel":"OVERVIEW","title":"Myopathy Rehabilitation: Restoring Muscle Health & Function","paragraphs":["Myopathies are diseases of the muscle itself — conditions where the primary problem lies in the muscle fiber rather than the nerve supplying it. They cause progressive weakness, exercise intolerance, muscle pain (myalgia), and in severe cases, respiratory muscle failure.","At Ayurgreen Hospital, our Myopathy Program provides expert diagnosis and comprehensive management for all types of myopathies — from inflammatory myopathies (polymyositis, dermatomyositis) to metabolic and genetic myopathies. Our approach combines the most current medical therapies with carefully calibrated exercise rehabilitation and Ayurvedic muscle-healing therapies.","The key challenge in myopathy rehabilitation is finding the precise balance of exercise — enough to maintain and build remaining muscle strength, without the overexertion that can worsen muscle damage in some types of myopathy. Our expert team navigates this delicate balance with precision."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Myopathy at Ayurgreen Hospital"},"conditions":{"sectionLabel":"MYOPATHY TYPES WE TREAT","sectionTitle":"Types of Myopathy We Manage","sectionSupport":"Expert diagnosis and management for all categories of inherited and acquired muscle diseases.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Inflammatory Myopathies","description":"Polymyositis, Dermatomyositis, and Inclusion Body Myositis — autoimmune conditions causing progressive muscle inflammation and weakness. Expert medical management with immunosuppressive therapy combined with targeted exercise rehabilitation."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Metabolic & Genetic Myopathies","description":"Mitochondrial myopathies, Glycogen storage disorders (Pompe disease), and Lipid storage myopathies. Expert management of the metabolic needs alongside careful, calibrated exercise programs."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Drug-Induced & Critical Illness Myopathy","description":"Myopathy caused by statin use, corticosteroids, or ICU critical illness — requiring careful medication review and intensive rehabilitation to recover muscle function and strength."}]},"treatments":{"sectionLabel":"MYOPATHY MANAGEMENT","sectionTitle":"Comprehensive Myopathy Care","sectionSupport":"Expert medical management and carefully calibrated exercise rehabilitation for optimal muscle health.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Specialized Myopathy Physiotherapy","description":"Expert, carefully calibrated exercise programs for myopathy — balancing the critical need for strengthening exercise against the risk of overexertion. Sub-maximal aerobic exercise, resistance training at appropriate intensities, aquatic therapy, and breathing exercises are all incorporated with continuous monitoring for signs of exercise intolerance."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Muscle-Healing Therapies","description":"Kerala Ayurveda excels in managing muscular weakness with therapies specifically designed to nourish and strengthen muscles: Njavara Kizhi (rice bundle therapy) is particularly powerful for rebuilding muscle bulk and strength; Abhyanga with medicated oils improves muscle circulation; Bala Ashwagandha formulations are classic Ayurvedic muscle tonics with emerging scientific evidence for muscle health."},{"image":"Assets/rehab/th_robotic.webp","title":"Robotic-Assisted Exercise for Myopathy","description":"For patients with significant weakness, robotic assistance enables exercise that would otherwise be impossible — allowing movement training without the risk of overexertion. The G-EO system provides body-weight supported walking, and Armotion enables arm exercise with varying levels of assistance calibrated precisely to the patient's current strength."},{"image":"Assets/rehab/prog_stroke.webp","title":"Respiratory Muscle Management","description":"Many myopathies affect the respiratory muscles, causing breathlessness and respiratory failure. Our respiratory therapists perform regular monitoring, provide respiratory muscle training (inspiratory muscle training), and implement non-invasive ventilation when needed."}]},"technologies":{"sectionLabel":"MYOPATHY CARE TECHNOLOGY","sectionTitle":"Technology for Myopathy Rehabilitation","sectionSupport":"Precision exercise technology and Ayurvedic muscle therapies for comprehensive myopathy management.","cards":[{"icon":"activity","title":"Exercise Monitoring Systems","description":"Continuous heart rate, oxygen saturation, and perceived exertion monitoring during exercise to precisely calibrate training intensity and prevent overexertion in myopathy patients."},{"icon":"waves","title":"Aquatic Therapy (AquaCiser III)","description":"Hydrotherapy enabling exercise with reduced gravitational loading — ideal for myopathy patients who cannot perform land-based exercise due to weakness or pain."},{"icon":"leaf","title":"Njavara Kizhi & Bala Ashwagandha","description":"Traditional Ayurvedic muscle-building therapies with emerging scientific support for muscle protein synthesis, strength improvement, and anti-inflammatory effects."},{"icon":"wind","title":"Inspiratory Muscle Training","description":"Targeted respiratory muscle strengthening for myopathy patients with diaphragm and intercostal muscle involvement, delaying the need for ventilatory support."},{"icon":"bot","title":"Assisted Robotic Exercise","description":"Robotic-assisted movement training allowing precise control of exercise load — enabling meaningful muscle training even in patients with severe weakness."}]},"faq":{"sectionSupport":"Find answers to key details about the Myopathy program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Myopathy combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","aTcEUdFmUrfcHx8gSrqvw",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
