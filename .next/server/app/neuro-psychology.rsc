8:T653,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/neuro-psychology#webpage","url":"https://ayurgreenhospital.com/neuro-psychology","name":"Neuro Psychology | Ayurgreen Hospital","description":"Cognitive retraining, sensory stimulation, emotional support, and clinical guidance to rebuild cerebral pathways and coordinate focus.","about":{"@type":"MedicalSpecialty","name":"Neuro Psychology"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/neuro-psychology#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Modern Integrations","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Neuro Psychology","item":"https://ayurgreenhospital.com/neuro-psychology"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/neuro-psychology#service","name":"Neuro Psychology","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Cognitive retraining, sensory stimulation, emotional support, and clinical guidance to rebuild cerebral pathways and coordinate focus."}]}0:{"P":null,"b":"8fOA1jbl6pU7Z3DXp6zXJ","p":"","c":["","neuro-psychology"],"i":false,"f":[[["",{"children":["neuro-psychology",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["neuro-psychology",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","neuro-psychology","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"neuro-psychology","sidebarId":"neuro-psychology","metaTitle":"Neuro Psychology | Ayurgreen Hospital","metaDescription":"Cognitive retraining, sensory stimulation, emotional support, and clinical guidance to rebuild cerebral pathways and coordinate focus.","canonicalPath":"/neuro-psychology","hero":{"bannerImage":"Assets/rehab/th_vr.webp","label":"Modern Integrations","breadcrumbCategory":"Modern Integrations","title":"Neuro Psychology","subtitle":"Cognitive retraining, sensory stimulation, emotional support, and clinical guidance to rebuild cerebral pathways and coordinate focus."},"overview":{"sectionLabel":"OVERVIEW","title":"Neuro-Psychology: Mind, Cognition & Emotional Recovery","paragraphs":["Neurological conditions don't just affect the body — they profoundly impact the mind. A stroke or traumatic brain injury can cause cognitive difficulties (problems with memory, attention, and thinking), significant emotional changes (depression, anxiety, emotional lability), and behavioral alterations that are as debilitating as physical deficits.","At Ayurgreen Hospital, our Neuropsychology Department addresses this critically important and often overlooked dimension of neurological recovery. A patient who regains walking ability but cannot plan, remember, or control emotions cannot return to independent life.","Our clinical neuropsychologists, clinical psychologists, and counselors work as an integrated team to assess and treat the cognitive and emotional consequences of brain injury, stroke, and neurological disease — while simultaneously supporting the enormous psychological challenges of long-term rehabilitation and life adjustment that patients and families face."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Neuro Psychology at Ayurgreen Hospital"},"conditions":{"sectionLabel":"NEUROPSYCHOLOGICAL FOCUS","sectionTitle":"What We Assess & Treat","sectionSupport":"Comprehensive neuropsychological care for the cognitive, emotional, and behavioral consequences of brain and neurological conditions.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Acquired Cognitive Impairment","description":"Post-stroke cognitive deficits, traumatic brain injury-related cognitive dysfunction, and mild cognitive impairment (MCI). Challenges with memory, attention, processing speed, executive function, and language — formally assessed and addressed through structured cognitive rehabilitation."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Emotional & Mood Disorders","description":"Depression (affecting up to 40% of stroke survivors), anxiety disorders, post-traumatic stress disorder (PTSD), and emotional lability (sudden uncontrollable crying or laughing) — all of which dramatically impair rehabilitation engagement and recovery outcomes."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Family & Caregiver Psychological Support","description":"The psychological burden on family members and caregivers of neurological patients is immense. Our team provides dedicated counseling, coping strategies, and support groups for family members to prevent caregiver burnout and maintain the family's capacity to support the patient's recovery journey."}]},"treatments":{"sectionLabel":"NEUROPSYCH SERVICES","sectionTitle":"Comprehensive Neuropsychological Services","sectionSupport":"Integrated assessment and treatment of the cognitive, emotional, and behavioral dimensions of neurological recovery.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Comprehensive Neuropsychological Assessment","description":"Our neuropsychologists perform standardized, comprehensive cognitive assessments to precisely map each patient's cognitive profile — identifying specific deficits in memory, attention, executive function, language, and processing speed. This detailed map is essential for designing targeted cognitive rehabilitation strategies and for medicolegal and vocational rehabilitation purposes."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Cognitive Rehabilitation Therapy","description":"Structured, evidence-based cognitive rehabilitation programs targeting the specific cognitive deficits identified during assessment. Approaches include attention process training, memory strategy training, executive function retraining, and computer-assisted cognitive remediation. Integrated with our VR cognitive rehabilitation suite for engaging, measurable cognitive therapy."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Psychological Therapy & Mental Health Support","description":"Individual and group Cognitive Behavioral Therapy (CBT) for depression and anxiety. Acceptance and Commitment Therapy (ACT) and mindfulness-based stress reduction (MBSR) for adjustment to disability and chronic illness. Dedicated PTSD treatment protocols for trauma following sudden neurological events."},{"image":"Assets/rehab/th_ayurveda.webp","title":"Ayurvedic Mind-Body Integration","description":"Ayurveda's Sattva-promoting (mental clarity) therapies — including Shirodhara (for stress and anxiety), Brahmi and Ashwagandha rasayanas (for cognitive enhancement and anxiety reduction), and Yoga Nidra (yogic sleep) — provide powerful, natural support for the emotional and cognitive recovery journey alongside evidence-based psychological therapies."}]},"technologies":{"sectionLabel":"NEUROPSYCH CAPABILITIES","sectionTitle":"Neuropsychological Technology & Tools","sectionSupport":"Advanced cognitive assessment tools and evidence-based therapeutic approaches for comprehensive neuropsychological rehabilitation.","cards":[{"icon":"brain","title":"Standardized Cognitive Assessment Batteries","description":"Comprehensive validated neuropsychological testing including MMSE, MoCA, WAIS, Wechsler Memory Scale, BADS, and Trail Making Tests for precise cognitive profiling."},{"icon":"headset","title":"VR Cognitive Rehabilitation","description":"Immersive virtual reality environments for engaging, gamified cognitive training — targeting attention, memory, and executive function in a motivating and measurable way."},{"icon":"heart-handshake","title":"CBT & Mindfulness Therapy","description":"Evidence-based individual and group psychotherapy including CBT, ACT, and MBSR delivered by qualified clinical psychologists for depression, anxiety, and adjustment disorders."},{"icon":"leaf","title":"Ayurvedic Medhya Rasayanas","description":"Brahmi, Shankhapushpi, and Ashwagandha-based herbal formulations (Medhya Rasayanas) proven in research to enhance memory, reduce anxiety, and support nervous system health."},{"icon":"users","title":"Family Therapy & Support Groups","description":"Structured family counseling sessions and peer support groups for both patients and caregivers to address relationship dynamics, caregiver burden, and community reintegration."}]},"faq":{"sectionSupport":"Find answers to key details about the Neuro Psychology program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Neuro Psychology combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","CGt1yw5I5MrM2xGbIqGxM",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
