k"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["neurology",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","neurology","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"neurology","sidebarId":"neurology","metaTitle":"Neurology | Ayurgreen Hospital","metaDescription":"Advanced neurological diagnostics, consultation, and coordinated recovery paths for stroke, neuropathy, and brain lesions.","canonicalPath":"/neurology","hero":{"bannerImage":"Assets/rehab/prog_stroke.webp","label":"Modern Integrations","breadcrumbCategory":"Modern Integrations","title":"Neurology","subtitle":"Advanced neurological diagnostics, consultation, and coordinated recovery paths for stroke, neuropathy, and brain lesions."},"overview":{"sectionLabel":"OVERVIEW","title":"Advanced Neurology: Precise Diagnosis, Integrated Care","paragraphs":["The nervous system — encompassing the brain, spinal cord, and peripheral nerves — is the most intricate and vital network in the human body. Neurological diseases can disrupt every aspect of daily life, from a person's ability to walk and speak to their capacity to think, remember, and feel. Expert neurological care is, therefore, not just about treating disease; it is about preserving a person's entire quality of life.","At Ayurgreen Hospital, our Neurology Department provides exceptional, compassionate care for the full spectrum of neurological conditions. Our specialist neurologists combine the most advanced diagnostic tools with evidence-based medical treatments and seamlessly integrate them with our world-class rehabilitation and holistic Ayurvedic care.","As India's first robotic-integrated neuro rehabilitation center, we understand that the journey from neurological diagnosis to complete functional recovery requires an unbroken continuum of expert, specialized care — all of which we provide under one roof."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Neurology at Ayurgreen Hospital"},"conditions":{"sectionLabel":"CONDITIONS WE TREAT","sectionTitle":"Neurological Conditions We Specialize In","sectionSupport":"Our specialist neurologists provide expert care for the full spectrum of brain, spine, and nerve conditions.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Vascular & Degenerative Disorders","description":"Stroke, transient ischemic attacks (TIAs), brain aneurysms, Parkinson's disease, Alzheimer's disease, and other forms of dementia requiring long-term neurological management."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Demyelinating & Functional Disorders","description":"Multiple Sclerosis (MS), Guillain-Barré syndrome, epilepsy, chronic migraines, and severe vertigo — conditions that significantly impact daily functioning and quality of life."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Spinal Cord & Nerve Issues","description":"Sciatica, severe neuropathy, and radiculopathy — conditions involving nerve compression or damage that cause pain, weakness, and sensory disturbances throughout the body."}]},"treatments":{"sectionLabel":"CLINICAL SERVICES","sectionTitle":"Comprehensive Neurological Services","sectionSupport":"Our specialist neurologists combine advanced diagnostics with evidence-based treatment and holistic Ayurvedic neurotherapy.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Advanced Neurological Diagnostics","description":"Precise diagnosis is the foundation of effective neurological treatment. We utilize advanced diagnostic tools including Nerve Conduction Studies (NCS) and Electromyography (EMG) to map nerve damage, Electroencephalography (EEG) to diagnose epilepsy, and expert MRI and CT scan interpretation to identify brain and spine lesions and vascular abnormalities."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Medical Neurology Management","description":"Our neurology team manages the complete medical treatment of all neurological conditions using evidence-based pharmacology. Specialized services include Epilepsy Management with precise anti-epileptic regimens, Headache and Migraine Clinics, Botox Injections for spasticity and chronic migraines, and expert management of Parkinson's and multiple sclerosis through disease-modifying therapies."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Neurological Therapies","description":"As a first-of-its-kind integrated center, our neurologists collaborate directly with Ayurvedic physicians to provide holistic neurological care. Treatments like Shirodhara (calming oil therapy for migraines and Parkinson's), Nasyam (nasal therapies stimulating brain centers), and powerful Rasayana herbal formulations work synergistically with modern medications to slow neurological degeneration and enhance brain function naturally."},{"image":"Assets/rehab/th_robotic.webp","title":"Neurological Rehabilitation Integration","description":"Following a neurological diagnosis, our patients transition seamlessly into our world-class rehabilitation ecosystem. Our neurologists directly oversee the robotic rehabilitation protocols, ensuring that all physical therapies are medically safe and aligned with the patient's neurological recovery stage — a continuity of care impossible to find elsewhere."}]},"technologies":{"sectionLabel":"INTEGRATED INNOVATION","sectionTitle":"Diagnostic & Treatment Technology","sectionSupport":"Advanced neurological diagnostics paired with robotic rehabilitation and authentic Ayurvedic neurological care.","cards":[{"icon":"activity","title":"EMG & Nerve Conduction Studies","description":"Precision electrodiagnostic testing to identify and map nerve damage, muscle disease, and neuromuscular junction disorders — the foundation of accurate neurological diagnosis."},{"icon":"brain","title":"EEG (Electroencephalography)","description":"Advanced brain wave monitoring to diagnose and manage epilepsy, sleep disorders, and other conditions affecting brain electrical activity."},{"icon":"syringe","title":"Botox & Spasticity Management","description":"Targeted botulinum toxin injections to relieve severe post-stroke spasticity and manage chronic migraines, enabling more effective physiotherapy and improved comfort."},{"icon":"leaf","title":"Ayurvedic Neurotherapy","description":"Shirodhara, Nasyam, and Rasayana herbal formulations working synergistically with modern medications to slow neurological degeneration and enhance brain function naturally."},{"icon":"bot","title":"Robotic Neuro Rehabilitation","description":"Direct neurologist oversight of robotic rehabilitation protocols, ensuring all physical therapies align with the patient's neurological recovery stage for safe, accelerated progress."}]},"faq":{"sectionSupport":"Find answers to key details about the Neurology program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Neurology combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","d_v41RbqVRWWBa3DozayF",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
