8:T629,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/neurosurgery#webpage","url":"https://ayurgreenhospital.com/neurosurgery","name":"Neurosurgery | Ayurgreen Hospital","description":"Comprehensive clinical support, post-operative tracking, and integrated neuro rehab immediately following brain or spine surgeries.","about":{"@type":"MedicalSpecialty","name":"Neurosurgery"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/neurosurgery#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Modern Integrations","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Neurosurgery","item":"https://ayurgreenhospital.com/neurosurgery"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/neurosurgery#service","name":"Neurosurgery","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Comprehensive clinical support, post-operative tracking, and integrated neuro rehab immediately following brain or spine surgeries."}]}0:{"P":null,"b":"8fOA1jbl6pU7Z3DXp6zXJ","p":"","c":["","neurosurgery"],"i":false,"f":[[["",{"children":["neurosurgery",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["neurosurgery",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","neurosurgery","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"neurosurgery","sidebarId":"neurosurgery","metaTitle":"Neurosurgery | Ayurgreen Hospital","metaDescription":"Comprehensive clinical support, post-operative tracking, and integrated neuro rehab immediately following brain or spine surgeries.","canonicalPath":"/neurosurgery","hero":{"bannerImage":"Assets/rehab/prog_tbi.webp","label":"Modern Integrations","breadcrumbCategory":"Modern Integrations","title":"Neurosurgery","subtitle":"Comprehensive clinical support, post-operative tracking, and integrated neuro rehab immediately following brain or spine surgeries."},"overview":{"sectionLabel":"OVERVIEW","title":"Neurosurgery: Precision, Safety & Integrated Recovery","paragraphs":["Neurosurgery addresses the most critical and complex conditions of the brain, spinal cord, and peripheral nervous system. It requires not only unparalleled surgical precision but also an exceptionally planned post-operative rehabilitation journey to restore full function and quality of life.","At Ayurgreen Hospital, our Neurosurgery Department provides world-class surgical expertise for a wide range of conditions, from complex spinal disorders and brain tumors to traumatic injuries. What makes our approach exceptional is the seamless integration between surgery and our comprehensive rehabilitation ecosystem.","Our neurosurgeons work in direct collaboration with neurologists, rehabilitation physicians, physiotherapists, and Ayurvedic physicians. This means that from the moment you are admitted for surgery, your complete post-operative recovery plan — including robotic rehabilitation and Ayurvedic healing — is already being designed by the same team that will perform your procedure."],"image":"Assets/rehab/prog_spinal_cord.webp","imageAlt":"Neurosurgery at Ayurgreen Hospital"},"conditions":{"sectionLabel":"SURGICAL SPECIALIZATIONS","sectionTitle":"Neurosurgical Conditions We Address","sectionSupport":"Our neurosurgeons provide expert surgical care for complex conditions of the brain, spine, and nervous system.","cards":[{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Spine Surgery","description":"Minimally invasive procedures for herniated discs, spinal stenosis, spondylolisthesis, and deformities. Our surgeons use advanced endoscopic and microscopic techniques for faster recovery and less surgical trauma."},{"image":"Assets/rehab/prog_stroke.webp","title":"Brain & Skull Base Surgery","description":"Expert surgical management of brain tumors (gliomas, meningiomas, pituitary adenomas), cerebrovascular disorders (aneurysms, AVMs), and intracerebral hemorrhages with the goal of maximum tumor removal and function preservation."},{"image":"Assets/rehab/prog_tbi.webp","title":"Neuro-Trauma & Nerve Surgery","description":"Emergency and elective surgical management of traumatic brain injuries, spinal cord injuries, and peripheral nerve injuries including nerve repair, grafting, and decompression procedures."}]},"treatments":{"sectionLabel":"SURGICAL & POST-OP SERVICES","sectionTitle":"Comprehensive Neurosurgical Care","sectionSupport":"Expert surgical procedures combined with our world-class post-operative rehabilitation ecosystem for complete, lasting recovery.","steps":[{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Minimally Invasive Spine Surgery (MISS)","description":"Using advanced endoscopic and microscopic techniques, our surgeons address herniated discs, spinal stenosis, and spinal deformities through the smallest possible incisions. MISS results in significantly less blood loss, reduced hospital stays, minimal post-operative pain, and a much faster return to rehabilitation and daily activities compared to open surgery."},{"image":"Assets/rehab/prog_stroke.webp","title":"Brain Surgery & Neuro-Oncology","description":"Our neurosurgeons specialize in complex brain tumor surgery (gliomas, meningiomas, pituitary adenomas) using intraoperative imaging and neurophysiological monitoring to maximize tumor removal while preserving eloquent brain function. We also perform vascular neurosurgery for aneurysms and AVMs, alongside CSF management procedures like VP shunting for hydrocephalus."},{"image":"Assets/rehab/th_robotic.webp","title":"Integrated Post-Surgical Rehabilitation","description":"Immediately following surgery, patients enter our intensive rehabilitation program. Our neurosurgeons directly prescribe the robotic gait, arm therapy, and physiotherapy protocols appropriate for each patient's surgical recovery stage. Ayurvedic post-operative healing — including wound-healing formulations and anti-inflammatory therapies — is initiated immediately to reduce swelling, accelerate tissue repair, and prepare the nervous system for rehabilitation."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Post-Operative Healing","description":"Specialized Ayurvedic formulations and therapies to optimize post-surgical healing. Ksheeradhara and gentle Abhyanga (therapeutic massage) reduce inflammatory swelling and promote healthy tissue regeneration. Rasayana (rejuvenating) therapies help rebuild neurological strength and vitality, creating an internal environment that is optimally supportive of neuroplasticity and motor recovery."}]},"technologies":{"sectionLabel":"SURGICAL EXPERTISE","sectionTitle":"Surgical Technology & Techniques","sectionSupport":"Cutting-edge surgical capabilities combined with the most comprehensive post-operative rehabilitation ecosystem in India.","cards":[{"icon":"microscope","title":"Endoscopic & Microscopic Surgery","description":"Minimally invasive surgical techniques using endoscopes and operative microscopes, enabling complex procedures with smaller incisions, less pain, and faster post-operative recovery."},{"icon":"brain","title":"Intraoperative Neuro-Monitoring","description":"Real-time neurophysiological monitoring (IONM) during complex brain and spine procedures to protect critical neural pathways and minimize surgical risk."},{"icon":"bot","title":"Post-Op Robotic Rehabilitation","description":"Immediate post-surgical transition to robotic gait training (G-EO System) and arm rehabilitation (Armotion), directly supervised by the neurosurgical team for medically safe, accelerated recovery."},{"icon":"leaf","title":"Ayurvedic Surgical Recovery","description":"Specialized Ayurvedic formulations (Ksheeradhara, Abhyanga, Rasayana therapies) to reduce post-surgical inflammation, accelerate wound healing, and support neuroplasticity during the critical early recovery phase."},{"icon":"clipboard-list","title":"CSF Management & VP Shunting","description":"Expert management of cerebrospinal fluid disorders including hydrocephalus through precision placement of ventriculoperitoneal shunts and endoscopic ventriculostomy procedures."}]},"faq":{"sectionSupport":"Find answers to key details about the Neurosurgery program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Neurosurgery combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","iRTAY9rq8Uy-d57S6b38r",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
