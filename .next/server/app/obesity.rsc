"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["obesity",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","obesity","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"obesity","sidebarId":"obesity","metaTitle":"Obesity Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Scientific metabolic control, customized Ayurvedic powder massages, low-impact exercise, and customized diet plans.","canonicalPath":"/obesity","hero":{"bannerImage":"Assets/AG Sub-pages Banner/Obesity.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Obesity","subtitle":"Scientific metabolic control, customized Ayurvedic powder massages, low-impact exercise, and customized diet plans."},"overview":{"sectionLabel":"OVERVIEW","title":"Obesity Management: Medical, Rehabilitative & Ayurvedic Solutions","paragraphs":["Obesity is a complex, multifactorial chronic disease — not simply a lifestyle choice or a failure of willpower. It involves genetic predisposition, hormonal dysfunction, metabolic changes, psychological factors, and environmental influences. Obesity significantly increases the risk of diabetes, hypertension, heart disease, stroke, joint disease, and many cancers.","At Ayurgreen Hospital, we provide a comprehensive, medically supervised Obesity Management Program that addresses all the dimensions of obesity — metabolic, hormonal, behavioral, psychological, and physical. Our program is particularly relevant for our rehabilitation patients, as obesity significantly impairs recovery from neurological and orthopedic conditions.","Our unique approach combines evidence-based medical obesity treatment, a specialized exercise and rehabilitation program using our hydrotherapy pool (ideal for obese patients with joint pain), expert dietary counseling, behavioral therapy, and Kerala Ayurveda's powerful metabolic-balancing and weight management therapies."],"image":"Assets/Whatsapp%20Icon.webp","imageAlt":"Obesity at Ayurgreen Hospital"},"conditions":{"sectionLabel":"OBESITY CATEGORIES","sectionTitle":"Obesity & Related Conditions We Manage","sectionSupport":"Comprehensive weight management for all grades of obesity and its metabolic, joint, and rehabilitation complications.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Metabolic Syndrome & Obesity","description":"Obesity combined with type 2 diabetes, hypertension, dyslipidemia, and NAFLD — the metabolic syndrome. Comprehensive medical management targeting weight loss and all metabolic risk factors simultaneously."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Obesity with Orthopedic Complications","description":"Severe obesity causing or worsening knee and hip OA, making exercise extremely difficult. Our hydrotherapy program provides effective exercise without joint loading — a critical first step in the weight management journey."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Obesity in Neurological Rehabilitation","description":"Obesity significantly impairs neurological and orthopedic rehabilitation — reducing exercise tolerance, increasing joint loading, and worsening sleep apnea. Our integrated obesity program is essential for these patients to achieve their rehabilitation goals."}]},"treatments":{"sectionLabel":"OBESITY MANAGEMENT","sectionTitle":"Comprehensive Obesity Treatment Program","sectionSupport":"Evidence-based medical, rehabilitative, dietary, and Ayurvedic approaches for sustainable, healthy weight management.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Structured Exercise Rehabilitation","description":"Our exercise program for obesity begins in our hydrotherapy pool — where buoyancy dramatically reduces joint stress, enabling effective cardiovascular exercise even for severely obese patients with joint pain. Progressive land-based exercise, resistance training using the Huber 360 platform, and aerobic conditioning are added as fitness improves. All sessions are heart-rate monitored and medically supervised."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Weight Management Therapies","description":"Kerala Ayurveda has specific, time-tested approaches for obesity (Sthoulya Chikitsa). Udwarthanam (dry powder massage) — a powerful, stimulating massage that improves lymphatic drainage, reduces subcutaneous fat, and boosts metabolism — is a cornerstone of Ayurvedic weight management. Panchakarma detoxification (Virechana, Basti) corrects underlying metabolic dysfunction. Medohar Guggulu and Triphala formulations support healthy fat metabolism."},{"image":"Assets/rehab/prog_stroke.webp","title":"Medical Obesity Management","description":"Expert medical management of obesity including hormonal evaluation (thyroid, insulin resistance, polycystic ovary syndrome), anti-obesity pharmacotherapy (when indicated), management of all obesity comorbidities, sleep apnea diagnosis and treatment, and bariatric surgery referral for appropriate candidates — providing comprehensive evidence-based obesity medicine."},{"image":"Assets/rehab/th_ayurveda.webp","title":"Individualized Dietary Counseling","description":"Evidence-based, individualized dietary plans combining modern nutritional science with Ayurvedic dietary principles (Pathya-Apathya). Our dietitians create sustainable, culturally appropriate meal plans that support weight loss, manage metabolic comorbidities, and optimize nutrition for rehabilitation. Caloric and macronutrient targets are set individually based on metabolic assessment."}]},"technologies":{"sectionLabel":"OBESITY MANAGEMENT TECHNOLOGY","sectionTitle":"Advanced Obesity Treatment Capabilities","sectionSupport":"Comprehensive medical, exercise, and Ayurvedic technology for effective, sustainable obesity management.","cards":[{"icon":"waves","title":"Hydrotherapy for Obese Patients","description":"Buoyancy-assisted exercise in our hydrotherapy pool — enabling effective cardiovascular workout without painful joint loading, the ideal starting point for obese patients with orthopedic problems."},{"icon":"activity","title":"Metabolic Assessment","description":"Comprehensive metabolic evaluation including DEXA body composition analysis, resting metabolic rate testing, hormonal profiling, and insulin resistance assessment for personalized weight management."},{"icon":"leaf","title":"Udwarthanam & Medohar Guggulu","description":"Ayurvedic Udwarthanam (stimulating powder massage) boosting metabolism and lymphatic drainage, combined with Medohar Guggulu and Triphala formulations supporting healthy fat metabolism."},{"icon":"heart","title":"Cardiovascular Risk Management","description":"Simultaneous management of obesity-related cardiovascular risk factors including hypertension, dyslipidemia, and pre-diabetes — reducing the risk of heart disease and stroke."},{"icon":"sun","title":"Yoga & Mindfulness for Weight Management","description":"Yoga and mindfulness-based interventions addressing the psychological dimensions of obesity including emotional eating, body image, and stress-related weight gain."}]},"faq":{"sectionSupport":"Find answers to key details about the Obesity program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Obesity combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","EyB82COjiC8zALj7bW1KV",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
