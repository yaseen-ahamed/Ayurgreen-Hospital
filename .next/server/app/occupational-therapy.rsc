e":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["occupational-therapy",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","occupational-therapy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"occupational-therapy","sidebarId":"occupational-therapy","metaTitle":"Occupational Therapy | Ayurgreen Hospital","metaDescription":"Retraining coordination, task performance, and hand dexterity to achieve dynamic independence in activities of daily living.","canonicalPath":"/occupational-therapy","hero":{"bannerImage":"Assets/rehab/th_ot.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Occupational Therapy","subtitle":"Retraining coordination, task performance, and hand dexterity to achieve dynamic independence in activities of daily living."},"overview":{"sectionLabel":"OVERVIEW","title":"Occupational Therapy: Restoring the Ability to Live & Participate","paragraphs":["Occupational Therapy (OT) focuses on enabling people to participate in the activities that matter most to them — the daily \"occupations\" of self-care, work, leisure, and social participation. When a neurological or physical condition impairs these fundamental activities, occupational therapists are uniquely skilled to help restore function and independence.","At Ayurgreen Hospital, our Occupational Therapy team is an essential component of every rehabilitation program. Whether a patient is recovering from stroke, spinal cord injury, traumatic brain injury, or a complex orthopedic condition, OT bridges the gap between clinical recovery and real-world independent living.","Our occupational therapists work both in the clinical setting and in patients' real-life environments — assessing home layouts, recommending modifications, prescribing adaptive equipment, and training patients and caregivers in the skills needed for independent living."],"image":"Assets/rehab/th_physiotherapy.webp","imageAlt":"Occupational Therapy at Ayurgreen Hospital"},"conditions":{"sectionLabel":"OT CLINICAL FOCUS","sectionTitle":"What Our Occupational Therapists Address","sectionSupport":"Comprehensive occupational therapy addressing the functional, cognitive, and environmental dimensions of recovery.","cards":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Upper Limb & Hand Rehabilitation","description":"Fine motor skill retraining, hand function recovery after stroke or nerve injury, splinting for spasticity and contracture prevention, and functional task training for independence in self-care."},{"image":"Assets/rehab/prog_stroke.webp","title":"Activities of Daily Living (ADL) Training","description":"Systematic training in all self-care activities — dressing, grooming, bathing, toileting, meal preparation, and home management — using adaptive strategies and equipment where needed."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Cognitive Rehabilitation & Work Integration","description":"Addressing cognitive deficits (memory, attention, executive function) that impair occupational performance. Vocational rehabilitation and work hardening programs to support return to employment."}]},"treatments":{"sectionLabel":"OT SERVICES","sectionTitle":"Comprehensive Occupational Therapy Services","sectionSupport":"Expert occupational therapy addressing every dimension of functional independence from self-care to community participation.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Upper Limb Rehabilitation & Hand Therapy","description":"Intensive hand and arm rehabilitation using task-specific training, constraint-induced movement therapy (CIMT), splinting, mirror therapy, and functional electrical stimulation (FES). Our OTs work closely with the robotic team — the Armotion arm system provides high-repetition robotic training that OTs then translate into real functional tasks like writing, eating, and dressing."},{"image":"Assets/rehab/prog_stroke.webp","title":"ADL Training & Adaptive Strategies","description":"Systematic, task-specific training in all activities of daily living using graded assistance and adapted methods. One-handed dressing techniques, bathroom modification recommendations, kitchen adaptation, and provision of appropriate adaptive equipment (specialized utensils, grab rails, shower chairs) to maximize independence with minimal caregiver dependence."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Sensory Rehabilitation & Neuro-Re-education","description":"Sensory re-education programs for patients with reduced or abnormal sensation after stroke or nerve injury. Desensitization for hypersensitivity, sensory discrimination training, and compensatory strategies for sensory loss to prevent injury and improve functional hand use. Sensory integration therapy for children with developmental disorders."},{"image":"Assets/rehab/th_robotic.webp","title":"Home Assessment & Environmental Modification","description":"Pre-discharge home visits and detailed home assessment reports recommending structural modifications (ramps, grab rails, widened doorways) and equipment provision to ensure safe home return. Our OTs provide detailed written recommendations for contractors and comprehensive caregiver training in safe assistance techniques."}]},"technologies":{"sectionLabel":"OT TECHNOLOGY","sectionTitle":"Occupational Therapy Technology & Tools","sectionSupport":"Advanced assessment tools and technology for comprehensive, effective occupational therapy.","cards":[{"icon":"hand","title":"Armotion Robotic Arm System","description":"High-repetition robotic arm rehabilitation providing the training volume OTs translate into real functional improvements in dressing, eating, writing, and self-care."},{"icon":"activity","title":"Functional Assessment Tools","description":"Standardized functional assessment (FIM, Barthel Index, MBI) to precisely measure independence in ADLs and track functional progress throughout rehabilitation."},{"icon":"zap","title":"Functional Electrical Stimulation","description":"FES for hand opening, wrist extension, and functional grasping — enabling patients with severe upper limb weakness to perform functional tasks during therapy."},{"icon":"headset","title":"VR Functional Training","description":"Virtual reality task simulations for practicing functional tasks (kitchen activities, driving assessments, work tasks) in a safe, repeatable virtual environment."},{"icon":"puzzle","title":"Adaptive Equipment Library","description":"Comprehensive adaptive equipment library providing patients access to specialized cutlery, dressing aids, communication devices, and environmental control systems for maximum independence."}]},"faq":{"sectionSupport":"Find answers to key details about the Occupational Therapy program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Occupational Therapy combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","1dh_qccESpCAJOiOe8cAU",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
