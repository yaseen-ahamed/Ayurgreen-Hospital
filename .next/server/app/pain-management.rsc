404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["pain-management",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","pain-management","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"pain-management","sidebarId":"pain-management","metaTitle":"Pain Management | Ayurgreen Hospital","metaDescription":"Multi-disciplinary relief paths targeting acute or chronic back, joint, and nerve pain without dependence on heavy meds.","canonicalPath":"/pain-management","hero":{"bannerImage":"Assets/rehab/prog_sciatica.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Pain Management","subtitle":"Multi-disciplinary relief paths targeting acute or chronic back, joint, and nerve pain without dependence on heavy meds."},"overview":{"sectionLabel":"OVERVIEW","title":"Pain Management: Comprehensive Relief for Acute & Chronic Pain","paragraphs":["Chronic pain affects millions of people worldwide, significantly impairing daily functioning, mental health, relationships, and quality of life. In the neurological rehabilitation setting, pain is particularly complex — neuropathic pain (burning, electric, stabbing pain from nerve damage), spasticity-related pain, central sensitization, and musculoskeletal pain may all coexist and interact.","At Ayurgreen Hospital, our Pain Management Program provides comprehensive, multimodal management for all types of acute and chronic pain. Our pain specialists work alongside neurologists, physiotherapists, Ayurvedic physicians, and psychologists to address pain from all dimensions — biological, physical, psychological, and social.","Kerala Ayurveda's exceptional analgesic and anti-inflammatory capabilities — particularly medicated oil therapies (Kizhi, Pizhichil, Basti) and powerful herbal formulations — are uniquely valuable in our pain management approach, providing natural, deep, and lasting pain relief that complements modern interventional and pharmacological techniques."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Pain Management at Ayurgreen Hospital"},"conditions":{"sectionLabel":"PAIN CONDITIONS WE TREAT","sectionTitle":"Types of Pain We Specialize In","sectionSupport":"Expert management for all types of acute and chronic pain encountered in neurological and orthopedic rehabilitation.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Neuropathic Pain","description":"Central post-stroke pain, peripheral neuropathy, complex regional pain syndrome (CRPS), phantom limb pain, post-herpetic neuralgia, and chemotherapy-induced neuropathy — neuropathic conditions requiring specialized management."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Musculoskeletal & Spinal Pain","description":"Chronic back and neck pain, disc-related pain, facet arthropathy, myofascial pain syndrome, fibromyalgia, and post-surgical pain — managed with an integrated physiotherapy, injection, and Ayurvedic approach."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Rehabilitation-Related Pain","description":"Spasticity-related pain, shoulder pain (common in stroke and TBI), heterotopic ossification pain, contracture-related pain, and pressure sore pain — complex pain presentations common in neurological rehabilitation."}]},"treatments":{"sectionLabel":"PAIN MANAGEMENT SERVICES","sectionTitle":"Comprehensive Pain Management","sectionSupport":"Multimodal, evidence-based pain management addressing pain from all biological, physical, and psychological dimensions.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Interventional Pain Procedures","description":"Image-guided interventional pain procedures providing precise, targeted pain relief: Epidural Steroid Injections for radiculopathy and spinal stenosis; Selective Nerve Root Blocks; Facet Joint Injections and Radiofrequency Ablation (RFA) for facet arthropathy; Trigger Point Injections for myofascial pain; Botox for spasticity-related pain and CRPS; Stellate Ganglion Block for CRPS and complex pain syndromes."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Analgesia & Anti-Inflammatory Therapies","description":"Kerala Ayurveda provides outstanding natural pain management: Kizhi (herbal bundle fomentation) for musculoskeletal and neuropathic pain; Pizhichil (warm oil bath) for spasticity-related and central pain; Kati/Greeva Basti for disc and spinal pain; Shirodhara for migraine and tension headache; Basti (medicated enema) for neuropathic pain and sciatica. Powerful herbal analgesics (Dashmoola, Shallaki, Guggulu) provide systemic pain relief."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Physiotherapy & Physical Pain Management","description":"Evidence-based physiotherapy for pain: Manual therapy and mobilization for musculoskeletal pain; Dry needling for myofascial trigger point pain; TENS (Transcutaneous Electrical Nerve Stimulation) for acute and chronic pain; Ultrasound therapy for soft tissue healing; Graded Motor Imagery for CRPS and phantom pain; and progressive exercise therapy for chronic pain reconditioning."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Psychological Pain Management","description":"The psychological dimension of chronic pain is as important as the physical — pain catastrophizing, depression, anxiety, and sleep disturbance amplify pain experience and impair recovery. Our pain psychologists provide Pain-Focused CBT, Acceptance and Commitment Therapy (ACT), Mindfulness-Based Stress Reduction (MBSR), and sleep therapy — addressing the cognitive and emotional factors perpetuating chronic pain."}]},"technologies":{"sectionLabel":"PAIN MANAGEMENT TECHNOLOGY","sectionTitle":"Advanced Pain Treatment Capabilities","sectionSupport":"Comprehensive pain management technology from precision interventional procedures to Ayurvedic healing.","cards":[{"icon":"syringe","title":"Fluoroscopy-Guided Injections","description":"Image-guided precision injections (ESI, nerve blocks, facet injections, RFA) ensuring accurate needle placement for maximum therapeutic benefit and safety."},{"icon":"zap","title":"TENS & Electrotherapy","description":"Transcutaneous Electrical Nerve Stimulation, interferential therapy, and ultrasound for non-invasive, drug-free pain management complementing injection and Ayurvedic therapies."},{"icon":"leaf","title":"Kizhi & Basti Pain Therapy","description":"Kerala Ayurveda's most powerful analgesic treatments — Kizhi fomentation, warm Pizhichil, and Basti medicated enema — providing deep, natural pain relief for neuropathic, musculoskeletal, and spinal pain."},{"icon":"syringe","title":"Botox for Spasticity Pain","description":"Botulinum toxin injections for focal spasticity and associated pain — the most effective intervention for post-stroke and TBI spasticity-related pain, dramatically improving comfort and enabling rehabilitation."},{"icon":"brain","title":"Pain Psychology (CBT, ACT)","description":"Pain-focused cognitive behavioral therapy and mindfulness-based interventions addressing the psychological amplifiers of chronic pain for comprehensive, lasting pain relief."}]},"faq":{"sectionSupport":"Find answers to key details about the Pain Management program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Pain Management combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","IrU9HwijhtxBjZDRHbTNT",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
