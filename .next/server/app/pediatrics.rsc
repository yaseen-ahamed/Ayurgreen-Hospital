ildren":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["pediatrics",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","pediatrics","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"pediatrics","sidebarId":"pediatrics","metaTitle":"Pediatrics | Ayurgreen Hospital","metaDescription":"Comprehensive neurodevelopmental, occupational, and sensory care customized for children facing milestone challenges.","canonicalPath":"/pediatrics","hero":{"bannerImage":"Assets/rehab/prog_cerebral_palsy.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Pediatrics","subtitle":"Comprehensive neurodevelopmental, occupational, and sensory care customized for children facing milestone challenges."},"overview":{"sectionLabel":"OVERVIEW","title":"Pediatrics: Expert Care for Children's Health & Development","paragraphs":["Children are not simply small adults — they have unique medical, developmental, and psychological needs that require specialized expertise, tailored approaches, and a compassionate, family-centered philosophy of care. Pediatric healthcare must account for the rapidly changing nature of the developing body and brain, the critical impact of illness on educational and social development, and the central role of the family in a child's health.","At Ayurgreen Hospital, our Pediatrics Department provides comprehensive care for children from birth through adolescence, with particular expertise in the neurodevelopmental and rehabilitation needs that make us unique. Our pediatricians work in a family-centered model, partnering with parents as the true experts on their children.","Our pediatric services span general pediatric healthcare, developmental assessment, neonatal follow-up, and specialized pediatric rehabilitation for children with cerebral palsy, developmental delay, autism, muscular dystrophy, and neurological conditions."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Pediatrics at Ayurgreen Hospital"},"conditions":{"sectionLabel":"PEDIATRIC CONDITIONS","sectionTitle":"Pediatric Conditions We Specialize In","sectionSupport":"Comprehensive pediatric care for general health, development, and complex pediatric rehabilitation needs.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"General Pediatric Healthcare","description":"Comprehensive general pediatric services including acute illness management, vaccination, growth and development monitoring, nutritional assessment, and adolescent health — provided in a child-friendly, family-centered environment."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Neurodevelopmental Conditions","description":"Specialized pediatric expertise in cerebral palsy, autism spectrum disorder, global developmental delay, ADHD, learning disabilities, and childhood epilepsy — conditions requiring the multidisciplinary approach that Ayurgreen excels in."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Pediatric Rehabilitation","description":"Integrated pediatric rehabilitation for children with neurological, musculoskeletal, and neuromuscular conditions — combining physiotherapy, occupational therapy, speech therapy, and Ayurvedic pediatric therapies (Kumarabrityam)."}]},"treatments":{"sectionLabel":"PEDIATRIC SERVICES","sectionTitle":"Comprehensive Pediatric Care Services","sectionSupport":"Expert, family-centered pediatric care from general health through to complex neurodevelopmental rehabilitation.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"General & Developmental Pediatrics","description":"Complete general pediatric services: well-child checks, vaccination according to the national immunization schedule, growth monitoring, nutritional counseling, childhood illness management, and adolescent health clinics. Developmental screening at every well-child visit using validated tools (Denver II, ASQ) for early identification of developmental delay — enabling timely early intervention."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Pediatric Neurodevelopmental Rehabilitation","description":"Integrated rehabilitation for children with CP, developmental delay, and ASD: play-based physiotherapy using NDT and sensorimotor approaches; occupational therapy for fine motor development and sensory integration; speech therapy for communication development; and Ayurvedic Kumarabrityam therapies (pediatric Ayurveda) supporting neuromuscular development. All therapy is family-centered, with parents as active co-therapists."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Kumarabrityam (Pediatric Ayurveda)","description":"Kerala Ayurveda's specialized branch for child health — Kumarabrityam — provides powerful neuroprotective and developmental support for children. Abhyanga with Bala Ashwagandha oil for neuromuscular development; Suvarna Prashan (gold-fortified herbal preparations) for cognitive enhancement and immunity; Shiroabhyanga for brain development; and age-appropriate Rasayana formulations supporting physical and mental growth."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Childhood Epilepsy Management","description":"Expert management of childhood epilepsy including febrile seizures, generalized epilepsy syndromes (Lennox-Gastaut, CSWS), and focal epilepsies. Comprehensive EEG evaluation, optimal anti-epileptic drug selection, and Ketogenic Diet therapy where appropriate. Ayurvedic Medhya Rasayana (brain-nourishing) formulations as adjunctive therapy."}]},"technologies":{"sectionLabel":"PEDIATRIC CAPABILITIES","sectionTitle":"Advanced Pediatric Technology & Expertise","sectionSupport":"Comprehensive pediatric diagnostic and therapeutic capabilities for children of all ages and conditions.","cards":[{"icon":"baby","title":"Developmental Screening Suite","description":"Standardized developmental screening tools (Denver II, ASQ, MCHAT for autism) enabling early identification of developmental concerns for timely referral to early intervention."},{"icon":"brain","title":"Pediatric EEG","description":"Child-friendly EEG setup for diagnosis and monitoring of childhood epilepsy, including long-term video EEG monitoring for complex seizure disorders."},{"icon":"leaf","title":"Kumarabrityam Ayurveda","description":"Specialized Ayurvedic pediatric therapies (Abhyanga, Suvarna Prashan, Medhya Rasayana) supporting neurodevelopment, cognitive function, and immunity in children with health and developmental challenges."},{"icon":"activity","title":"Pediatric Physiotherapy Suite","description":"Child-friendly therapy equipment and sensory gym specifically designed for pediatric physiotherapy and occupational therapy — making therapy fun and effective for young patients."},{"icon":"heart-handshake","title":"Family-Centered Care Model","description":"Comprehensive parent and family education, coaching, and home program development — ensuring therapeutic progress continues 24/7 through family participation."}]},"faq":{"sectionSupport":"Find answers to key details about the Pediatrics program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Pediatrics combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","OEQKKpDSK5gIK_ST5hSlj",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
