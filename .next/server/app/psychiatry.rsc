8:T61f,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/psychiatry#webpage","url":"https://ayurgreenhospital.com/psychiatry","name":"Psychiatry Rehabilitation & Care | Ayurgreen Hospital","description":"Comprehensive clinical support, medication management, stress reduction, and integrated psychiatric guidance.","about":{"@type":"MedicalSpecialty","name":"Integrated Psychiatry Care"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/psychiatry#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Specialities","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Psychiatry","item":"https://ayurgreenhospital.com/psychiatry"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/psychiatry#service","name":"Psychiatry & Mental Health Care","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Comprehensive clinical support, medication management, stress reduction, and integrated psychiatric guidance."}]}0:{"P":null,"b":"z9hb0mSGmNt15dIV3Ejhr","p":"","c":["","psychiatry"],"i":false,"f":[[["",{"children":["psychiatry",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc6519ba76849.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["psychiatry",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","psychiatry","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"psychiatry","sidebarId":"psychiatry","metaTitle":"Psychiatry Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Comprehensive clinical support, medication management, stress reduction, and integrated psychiatric guidance.","canonicalPath":"/psychiatry","hero":{"bannerImage":"Assets/AG Sub-pages Banner/New/Psychiatry.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Psychiatry","subtitle":"Comprehensive clinical support, medication management, stress reduction, and integrated psychiatric guidance."},"overview":{"sectionLabel":"OVERVIEW","title":"Psychiatry: Expert Mental Health Care & Integration","paragraphs":["Psychiatry addresses serious mental health conditions — from schizophrenia and bipolar disorder to severe depression, OCD, and substance abuse. Expert psychiatric care requires both precision in diagnosis and a compassionate, holistic approach to treatment that addresses biological, psychological, and social dimensions of mental illness.","At Ayurgreen Hospital, our Psychiatry Department provides specialist mental health care for patients with primary psychiatric conditions, and critically, for the significant psychiatric comorbidities (depression, anxiety, PTSD, psychosis) that commonly occur alongside neurological and physical illness.","Our psychiatrists work as integral members of the rehabilitation team — managing psychiatric medications that may affect motor performance, identifying and treating depression that slows rehabilitation engagement, and providing specialized expertise in the psychiatric presentations of neurological disorders including post-stroke psychosis, TBI-related personality changes, and the neuropsychiatric aspects of Parkinson's and dementia."],"image":"Assets/AG%20Sub-pages%20Banner/Psychiatry.webp","imageAlt":"Psychiatry at Ayurgreen Hospital"},"conditions":{"sectionLabel":"PSYCHIATRIC CONDITIONS","sectionTitle":"Psychiatric Conditions We Specialize In","sectionSupport":"Expert psychiatric care for primary mental health conditions and the psychiatric dimensions of neurological illness.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Mood Disorders","description":"Major Depressive Disorder, Bipolar Affective Disorder, persistent depressive disorder (dysthymia). Expert psychopharmacological management combined with integrated psychological therapy."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Neuropsychiatric Conditions","description":"Post-stroke psychosis and mania, TBI-related behavioral changes, Parkinson's dementia and psychosis, frontotemporal dementia behavioral syndrome — neurological conditions with psychiatric presentations requiring specialist neuropsychiatric expertise."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Anxiety & Related Disorders","description":"Generalized Anxiety Disorder, Panic Disorder, OCD, and PTSD — conditions causing significant distress and impairment. Evidence-based combined psychopharmacological and psychotherapeutic management."}]},"treatments":{"sectionLabel":"PSYCHIATRIC SERVICES","sectionTitle":"Comprehensive Psychiatric Care","sectionSupport":"Expert psychiatric assessment, pharmacological management, and integrated psychological therapy for complete mental health care.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Specialist Psychiatric Assessment & Diagnosis","description":"Comprehensive biopsychosocial psychiatric assessments establishing precise psychiatric diagnoses. Neuropsychiatric evaluation for complex presentations at the interface of neurology and psychiatry. Risk assessment for self-harm and suicidality with appropriate safety planning. Capacity assessment for medico-legal and treatment decision-making purposes."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Expert Psychopharmacology","description":"Specialist prescribing and monitoring of psychiatric medications — antidepressants, mood stabilizers, antipsychotics, anxiolytics, and cognitive enhancers. Critical expertise in managing psychiatric medications in neurologically impaired patients where drug choices must account for seizure risk, interaction with anti-Parkinsonian medications, and cognitive effects."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Integrative Ayurvedic Psychiatry","description":"Ayurveda's Manas Roga Chikitsa (treatment of mind diseases) provides powerful adjuncts to modern psychiatric treatment. Shirodhara with Brahmi oil for anxiety and bipolar depression; Satvavajaya Chikitsa (Ayurvedic cognitive-behavioral approaches); Brahmi, Jatamansi, and Shankhapushpi for OCD, anxiety, and cognitive symptoms; Panchagavya Ghrita for chronic psychiatric conditions — all integrated with modern psychiatric care."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Rehabilitation Psychiatry","description":"Specialist psychiatric oversight of all rehabilitation patients — proactive identification and treatment of depression, anxiety, delirium, and agitation that impair rehabilitation engagement. Psychiatric liaison for complex cases involving medical-psychiatric comorbidity. Medication review ensuring psychiatric drugs do not impair motor learning or increase fall risk during intensive rehabilitation."}]},"technologies":{"sectionLabel":"PSYCHIATRIC CAPABILITIES","sectionTitle":"Advanced Psychiatric Services","sectionSupport":"Expert psychiatric assessment, treatment, and integration with our world-class neurological rehabilitation team.","cards":[{"icon":"brain","title":"Psychiatric Assessment Batteries","description":"Comprehensive validated psychiatric assessment tools (BPRS, PANSS, HDRS, YMRS, Y-BOCS) for precise diagnosis and treatment monitoring across all psychiatric conditions."},{"icon":"activity","title":"Psychopharmacology Expertise","description":"Specialist psychiatric prescribing expertise including complex polypharmacy management, therapeutic drug monitoring, and careful medication selection for neurologically impaired patients."},{"icon":"leaf","title":"Ayurvedic Manas Roga Therapies","description":"Brahmi, Jatamansi, and Shankhapushpi formulations combined with Shirodhara and Satvavajaya Chikitsa providing powerful Ayurvedic adjuncts to modern psychiatric pharmacotherapy."},{"icon":"heart-handshake","title":"Family Psychoeducation","description":"Comprehensive family psychoeducation programs for major psychiatric conditions — improving medication adherence, reducing relapse, and building family capacity to support their loved one's mental health."},{"icon":"users","title":"Multidisciplinary Mental Health Team","description":"Integrated mental health team including psychiatrists, clinical psychologists, and counselors working together and embedded within the rehabilitation multidisciplinary team."}]},"faq":{"sectionSupport":"Find answers to key details about the Psychiatry program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Psychiatry combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","lREl91Z_y2tbnjdpkfiby",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
