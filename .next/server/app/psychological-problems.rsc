 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["psychological-problems",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","psychological-problems","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"psychological-problems","sidebarId":"psychological","metaTitle":"Psychological Problems Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Integrated mental health care, biofeedback sessions, relaxation, and wellness counseling to improve emotional balance.","canonicalPath":"/psychological-problems","hero":{"bannerImage":"Assets/AG Sub-pages Banner/New/Psychological Problems.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Psychological Problems","subtitle":"Integrated mental health care, biofeedback sessions, relaxation, and wellness counseling to improve emotional balance."},"overview":{"sectionLabel":"OVERVIEW","title":"Psychological Rehabilitation: Healing Mind & Emotion in Recovery","paragraphs":["A neurological or physical illness is never just a physical experience. The psychological impact of disability, loss of independence, altered identity, relationship changes, and uncertain futures can be as devastating as the physical illness itself. And critically, untreated psychological problems significantly impair physical rehabilitation outcomes.","At Ayurgreen Hospital, psychological wellbeing is treated as a clinical priority — not an afterthought. Our clinical psychologists, neuropsychologists, and counselors are embedded within the rehabilitation team, working daily with patients and families to address the psychological dimensions of recovery.","Our approach combines evidence-based psychological therapies (CBT, ACT, mindfulness) with the profound mind-body healing power of Ayurveda — including Shirodhara, yoga, and Medhya Rasayana formulations — creating a holistic psychological rehabilitation experience."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Psychological Problems at Ayurgreen Hospital"},"conditions":{"sectionLabel":"PSYCHOLOGICAL CONDITIONS","sectionTitle":"Psychological Challenges We Address","sectionSupport":"Comprehensive psychological support for patients, families, and caregivers facing the emotional challenges of neurological and physical illness.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Post-Neurological Depression & Anxiety","description":"Depression affects up to 40% of stroke survivors and is extremely common after TBI, spinal cord injury, and chronic neurological conditions. Untreated depression dramatically slows rehabilitation — making early identification and treatment critical."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Adjustment Disorders & PTSD","description":"The sudden onset of disability from stroke, accident, or injury can cause acute PTSD and adjustment disorders. Targeted trauma-focused therapy and adjustment counseling helps patients and families process the enormity of these life changes."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Caregiver Burden & Family Support","description":"Families and caregivers of neurological patients experience profound stress, burnout, depression, and relationship strain. Dedicated caregiver support, counseling, and respite planning is an essential component of comprehensive rehabilitation."}]},"treatments":{"sectionLabel":"PSYCHOLOGICAL SERVICES","sectionTitle":"Comprehensive Psychological Support Services","sectionSupport":"Evidence-based psychological therapy integrated within our neurological and physical rehabilitation programs.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Cognitive Behavioral Therapy (CBT) & ACT","description":"Individual CBT for depression, anxiety, health anxiety, and panic disorder — evidence-based psychological therapies with the strongest research support. Acceptance and Commitment Therapy (ACT) for adjustment to chronic illness, disability, and significant life change. Mindfulness-Based Cognitive Therapy (MBCT) for depression prevention and emotional regulation."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Mind-Body Healing","description":"Ayurveda's Sattavajaya Chikitsa (psychological healing therapies) profoundly complement modern psychological therapy. Shirodhara (calming oil stream on the forehead) reduces anxiety, improves sleep, and calms emotional lability. Brahmi and Jatamansi rasayanas reduce anxiety and improve mood. Yoga and Yoga Nidra cultivate resilience and emotional equanimity. Abhyanga and sensory therapies ground and soothe the nervous system."},{"image":"Assets/rehab/prog_stroke.webp","title":"Family Counseling & Caregiver Support","description":"Structured family therapy and caregiver support programs addressing relationship dynamics, role changes, communication strategies, and caregiver burnout prevention. Our counselors facilitate family meetings and provide practical guidance on care planning, community resources, and long-term adjustment. Support groups connect families facing similar challenges."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"PTSD & Trauma Processing","description":"Trauma-focused Cognitive Behavioral Therapy (TF-CBT) and EMDR (Eye Movement Desensitization and Reprocessing) for post-traumatic stress disorder following sudden neurological events, accidents, or intensive care. Trauma-informed care principles guide all interactions across the rehabilitation team."}]},"technologies":{"sectionLabel":"PSYCHOLOGICAL SUPPORT TOOLS","sectionTitle":"Psychological Therapy Approaches & Tools","sectionSupport":"Evidence-based psychological therapies and Ayurvedic mind-body healing for complete emotional rehabilitation.","cards":[{"icon":"brain","title":"Psychological Assessment Tools","description":"Validated depression (PHQ-9), anxiety (GAD-7), PTSD (PCL-5), and quality of life assessment tools used at admission and regularly throughout rehabilitation to monitor psychological wellbeing and treatment response."},{"icon":"headset","title":"VR Anxiety & Phobia Treatment","description":"Virtual reality exposure therapy for specific phobias and PTSD — providing controlled, graduated exposure in a safe, repeatable virtual environment."},{"icon":"leaf","title":"Shirodhara & Ayurvedic Mood Therapy","description":"Shirodhara, Brahmi Rasayana, and Jatamansi formulations with significant evidence for anxiety, depression, and sleep disorder management as an integral part of psychological rehabilitation."},{"icon":"sun","title":"Yoga Nidra & Mindfulness","description":"Yoga Nidra (yogic sleep) and mindfulness-based interventions reducing anxiety, improving sleep quality, and cultivating the emotional resilience essential for long-term rehabilitation engagement."},{"icon":"heart-handshake","title":"Peer Support & Support Groups","description":"Structured peer support programs connecting patients with similar conditions and experiences — reducing isolation, building community, and sharing coping strategies."}]},"faq":{"sectionSupport":"Find answers to key details about the Psychological Problems program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Psychological Problems combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","NVOUiB-K4_FQUTq2eU6Nn",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
