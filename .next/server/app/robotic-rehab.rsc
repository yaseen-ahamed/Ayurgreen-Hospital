ll,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["robotic-rehab",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","robotic-rehab","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"robotic-rehab","sidebarId":"robotic-rehab","metaTitle":"Robotic Exoskeleton Therapy | Ayurgreen Hospital","metaDescription":"High-repetition, sensor-guided exoskeleton therapy designed to accelerate motor learning and rebuild walking patterns.","canonicalPath":"/robotic-rehab","hero":{"bannerImage":"Assets/generated/robotic_rehab_exo_1776281782213.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Robotic Exoskeleton Therapy","subtitle":"India's most advanced robotic gait trainers and arm rehabilitation systems providing exact, sensor-guided, high-repetition movement."},"overview":{"sectionLabel":"OVERVIEW","title":"Robotic Rehabilitation: The Future of Advanced Recovery","paragraphs":["As India's first robotic-integrated neuro rehabilitation center, Ayurgreen Hospital combines cutting-edge technology with clinical expertise to deliver highly precise, consistent, and effective therapy. Robotic Rehabilitation supports patients recovering from stroke, spinal cord injuries, brain injuries, and other neurological disorders through accuracy, repetition, and measurable progress.","Our advanced exoskeletons can guide patients through perfectly synchronized 1,000+ movements per session — a level of high-repetition training that is mathematically impossible through manual therapy alone. Intelligent bio-sensors detect exactly how much effort the patient is producing, providing just enough assistance to force active participation rather than passive motion."],"image":"Assets/rehab/th_robotic.webp","imageAlt":"Robotic Exoskeleton Therapy at Ayurgreen Hospital"},"conditions":{"sectionLabel":"ADVANCED SYSTEMS","sectionTitle":"Robotic Technologies at Ayurgreen","sectionSupport":"Each robotic therapy is customized based on the patient's condition, ensuring safe, progressive, and goal-oriented rehabilitation.","cards":[{"image":"Assets/rehab/th_robotic.webp","title":"Robotic Gait Training (G-EO System)","description":"This advanced Swiss system helps patients relearn walking through supported, repetitive movement patterns — improving balance, posture, and walking ability after stroke or spinal injuries."},{"image":"Assets/rehab/prog_stroke.webp","title":"Robotic Arm Therapy (Armotion)","description":"Designed to restore hand and arm function, focusing on improving grip strength, coordination, and fine motor skills essential for daily activities and self-care independence."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Huber 360 (USA)","description":"A dynamic rehabilitation platform enhancing strength, balance, flexibility, and posture through interactive training programs — widely used for both neurological and musculoskeletal recovery."}]},"treatments":{"sectionLabel":"HOW IT WORKS","sectionTitle":"How Robotic Rehabilitation Supports Recovery","sectionSupport":"Neurological conditions require repetitive, targeted exercises to retrain the brain and muscles — a process known as neuroplasticity. Robotic systems are specially designed to assist this process.","steps":[{"image":"Assets/rehab/th_robotic.webp","title":"High-Repetition Movement Training","description":"While a human therapist can guide 100 foot steps per session, our exoskeletons deliver 1,000+ precisely synchronized movements. This massive repetition of correct biometric movement is the core mechanism for rewiring the damaged brain."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Real-Time Sensory Biofeedback","description":"Real-time visual graphs on screens display the patient's active participation and muscle engagement, creating immediate cognitive feedback loops that accelerate motor learning and neuroplasticity."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Integration with Holistic Therapies","description":"Robotic rehabilitation is combined with Ayurveda, physiotherapy, occupational therapy, and speech therapy. While robotic systems improve physical function, holistic therapies support internal healing, mental well-being, and long-term recovery."}]},"technologies":{"sectionLabel":"CLINICAL ADVANTAGES","sectionTitle":"Benefits of Robotic Rehabilitation","sectionSupport":"Faster recovery, measurable outcomes, and a more engaging therapy experience compared to conventional methods.","cards":[{"icon":"trending-up","title":"Faster Motor Recovery","description":"Faster recovery of movement and mobility through high-repetition training. Improved muscle strength and coordination with enhanced balance and posture for daily life."},{"icon":"activity","title":"Real-Time Progress Tracking","description":"High precision and consistency in therapy with real-time performance tracking and measurable outcomes. Reduced risk of incorrect movements or strain during every session."},{"icon":"brain","title":"Neuroplasticity Stimulation","description":"Intelligent bio-sensors detect the patient's effort level and provide precisely calibrated assistance, forcing the brain to actively participate and form new neural pathways."},{"icon":"heart-handshake","title":"Engaging Patient Experience","description":"Motivating and engaging therapy sessions with personalized, adaptive treatment plans. Reduced recovery time compared to conventional manual therapy methods."}]},"faq":{"sectionSupport":"Find answers to key details about our Robotic Rehabilitation program.","items":[{"question":"Who is a candidate for robotic rehabilitation?","answer":"Patients recovering from stroke, spinal cord injuries, traumatic brain injuries, Parkinson's disease, cerebral palsy, and other neurological conditions that affect mobility and motor control can benefit from robotic rehabilitation."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists with extensive robotic rehabilitation expertise."},{"question":"How does robotic therapy compare to manual physiotherapy?","answer":"Robotic therapy delivers 1,000+ precise, repetitive movements per session compared to approximately 100 with manual therapy. This scale of repetition is the key driver of neuroplasticity and leads to significantly faster functional recovery outcomes."},{"question":"How many sessions will I need?","answer":"The number of sessions depends on the specific condition, severity, and individual progress. Most patients undergo daily sessions over a period of 14–45 days as part of an inpatient program, with outpatient follow-up as needed."},{"question":"Are Ayurvedic therapies combined with robotic treatment?","answer":"Absolutely. Ayurgreen's unique advantage is the simultaneous integration of robotic rehabilitation with authentic Kerala Ayurvedic therapies. While robots train the body biomechanically, Ayurveda soothe the nervous system and reduce spasticity internally."},{"question":"What is the daily schedule like?","answer":"A typical day includes active robotic gait or arm training in the morning, followed by physiotherapy or occupational therapy, and relaxing Ayurvedic treatments with counseling sessions in the afternoon."},{"question":"Can outpatient patients access robotic rehabilitation?","answer":"Yes, we offer robotic rehabilitation for both inpatients and outpatients. Sessions can be booked on a per-session basis for those who do not require residential admission."},{"question":"How do I book a robotic rehabilitation consultation?","answer":"You can book a consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly. We will arrange a clinical assessment and program recommendation."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","3QhAaKz8mldAKog7WJ1eo",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
