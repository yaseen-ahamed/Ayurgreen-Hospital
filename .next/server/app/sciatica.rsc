en":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["sciatica",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","sciatica","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"sciatica","sidebarId":"sciatica","metaTitle":"Sciatica Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Relieving sciatic nerve compression, reducing radiating pain, and rebuilding core strength to prevent future flare-ups.","canonicalPath":"/sciatica","hero":{"bannerImage":"Assets/AG Sub-pages Banner/New/Sciatica.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Sciatica","subtitle":"Relieving sciatic nerve compression, reducing radiating pain, and rebuilding core strength to prevent future flare-ups."},"overview":{"sectionLabel":"OVERVIEW","title":"Sciatica Treatment: Lasting Relief from Nerve Pain","paragraphs":["Sciatica is a symptom of nerve compression — typically involving the sciatic nerve, the largest nerve in the body — characterized by a radiating pain that travels from the lower back through the buttock and down the leg, often to the foot. It can range from a mild ache to an excruciating, disabling pain that makes sitting, standing, or walking extremely difficult.","The most common causes of sciatica are lumbar disc herniation (slipped disc), spinal stenosis (narrowing of the spinal canal), piriformis syndrome, and degenerative lumbar spondylosis. Accurate diagnosis of the underlying cause is critical to selecting the most effective treatment.","At Ayurgreen Hospital, we provide the most comprehensive sciatica management program available — combining accurate diagnosis, evidence-based physiotherapy, targeted interventional pain procedures, and Kerala Ayurveda's uniquely effective nerve-nourishing and anti-inflammatory therapies for complete, lasting relief."],"image":"Assets/AG%20Sub-pages%20Banner/Sciatica.webp","imageAlt":"Sciatica at Ayurgreen Hospital"},"conditions":{"sectionLabel":"SCIATICA CAUSES","sectionTitle":"Types of Sciatica We Treat","sectionSupport":"Accurate diagnosis and targeted treatment for all causes of sciatic nerve pain.","cards":[{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Disc-Related Sciatica","description":"The most common cause — a herniated lumbar disc (L4-L5 or L5-S1) compressing the sciatic nerve root. Conservative management with McKenzie physiotherapy and Kati Basti is highly effective; surgery reserved for neurological compromise or failed conservative treatment."},{"image":"Assets/rehab/prog_stroke.webp","title":"Spinal Stenosis & Spondylolisthesis","description":"Narrowing of the spinal canal or nerve root canals causing neurogenic claudication and sciatica. Physiotherapy, epidural injections, and in severe cases, surgical decompression."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Piriformis Syndrome","description":"Sciatic nerve compression by the piriformis muscle deep in the buttock — causing sciatica without disc herniation. Responds well to targeted physiotherapy, piriformis injections, and Ayurvedic massage therapies."}]},"treatments":{"sectionLabel":"SCIATICA TREATMENT","sectionTitle":"Comprehensive Sciatica Management","sectionSupport":"Evidence-based, multimodal sciatica treatment for rapid pain relief and lasting cure.","steps":[{"image":"Assets/rehab/th_physiotherapy.webp","title":"Evidence-Based Physiotherapy","description":"McKenzie Method (Mechanical Diagnosis and Therapy) is highly effective for disc-related sciatica, using specific directional exercises to centralize and eliminate leg pain. Neural mobilization (nerve flossing) relieves nerve adhesions and reduces neuropathic pain. Core stabilization exercises protect the spine and prevent recurrence. Postural correction addresses the mechanical factors driving disc irritation."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Nerve-Nourishing Therapy","description":"Kerala Ayurveda has specific, highly effective treatments for sciatica (called Gridhrasi in Ayurveda). Kati Basti directly nourishes the lumbar discs and nerve roots. Pinda Sweda (herbal fomentation) rapidly reduces nerve root inflammation. Basti (medicated enema therapy) — the most important Ayurvedic treatment for Vata-related conditions including sciatica — provides systemic nerve nourishment and anti-inflammatory effects. Dhanwantharam Tailam massage reduces nerve pain and muscle spasm."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Interventional Pain Management","description":"Fluoroscopy-guided Selective Nerve Root Blocks (SNRB) and Epidural Steroid Injections (ESI) provide targeted, rapid anti-inflammatory relief at the exact site of nerve compression. These procedures rapidly reduce sciatica pain and enable more effective participation in physiotherapy — significantly speeding overall recovery."},{"image":"Assets/rehab/th_robotic.webp","title":"Hydrotherapy & Aquatic Rehabilitation","description":"For patients with severe sciatica preventing land-based exercise, our hydrotherapy pool enables effective movement and core strengthening without spinal compression. Water-based neural stretching and progressive strengthening in warm water provides excellent pain relief and functional rehabilitation."}]},"technologies":{"sectionLabel":"SCIATICA TREATMENT TECHNOLOGY","sectionTitle":"Advanced Sciatica Management Capabilities","sectionSupport":"Comprehensive diagnosis and treatment technology for accurate, effective, and lasting sciatica relief.","cards":[{"icon":"activity","title":"MRI Nerve Root Assessment","description":"High-resolution lumbar MRI with expert radiological interpretation to precisely identify the level and cause of sciatic nerve compression."},{"icon":"leaf","title":"Kati Basti & Medicated Basti","description":"The most powerful Ayurvedic interventions for sciatica — lumbar oil retention (Kati Basti) and therapeutic enema (Basti) providing direct nerve nourishment and systemic anti-inflammatory effects."},{"icon":"syringe","title":"Fluoroscopy-Guided Nerve Blocks","description":"Selective Nerve Root Blocks and Epidural Steroid Injections under fluoroscopic guidance — precise, targeted anti-inflammatory treatment at the exact site of sciatic nerve compression."},{"icon":"waves","title":"Aquatic Neural Therapy","description":"Water-based physiotherapy enabling nerve mobilization and core strengthening without gravitational spinal compression — ideal for severe acute sciatica preventing land exercise."},{"icon":"activity","title":"EMG & Nerve Conduction Studies","description":"Electrodiagnostic testing to assess the severity of sciatic nerve damage, guide prognosis, and monitor recovery — particularly important for patients with significant weakness or numbness."}]},"faq":{"sectionSupport":"Find answers to key details about the Sciatica program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Sciatica combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","hIYhN4nxQeIurkAt4PVte",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
