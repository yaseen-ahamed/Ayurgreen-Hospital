l",null,{"lang":"en","suppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["slimming-treatment",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","slimming-treatment","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"slimming-treatment","sidebarId":"slimming-treatment","metaTitle":"Slimming Treatment | Ayurgreen Hospital","metaDescription":"Ayurvedic metabolic stimulation, dry herbal powder massage, custom yoga routines, and organic diets for healthy fat loss.","canonicalPath":"/slimming-treatment","hero":{"bannerImage":"Assets/rehab/th_aquatic.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Slimming Treatment","subtitle":"Ayurvedic metabolic stimulation, dry herbal powder massage, custom yoga routines, and organic diets for healthy fat loss."},"overview":{"sectionLabel":"OVERVIEW","title":"Slimming Treatment: Scientifically Guided Body Transformation","paragraphs":["Effective, lasting weight management is one of the most complex challenges in modern healthcare. At Ayurgreen Hospital, we approach slimming and body transformation as a serious medical and wellness undertaking — not a cosmetic quick fix. Our Slimming Treatment Program combines the most evidence-based medical, rehabilitative, dietary, and Ayurvedic approaches for sustainable, healthy body transformation.","Our program is designed for people across the spectrum — from those seeking to lose 5-10 kg for health improvement, to those with significant obesity and metabolic syndrome requiring medically supervised management. We offer the most comprehensive slimming program available — going far beyond simple diet advice to address the metabolic, hormonal, behavioral, and structural causes of excess weight.","Kerala Ayurveda's Sthoulya Chikitsa (treatment of obesity) — including the powerful Udwarthanam therapy and Medohar (fat-metabolizing) formulations — is at the heart of our Ayurvedic slimming approach, complementing modern medical and rehabilitative interventions for truly integrated body transformation."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Slimming Treatment at Ayurgreen Hospital"},"conditions":{"sectionLabel":"SLIMMING PROGRAM SUITABILITY","sectionTitle":"Our Slimming Program Addresses","sectionSupport":"Medically supervised, scientifically guided slimming for sustainable body transformation and improved health.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Overweight & Obesity","description":"Medically supervised weight loss for all grades of overweight and obesity, with comprehensive metabolic assessment and individually tailored programs combining diet, exercise, and Ayurvedic therapy."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Metabolic Syndrome & Comorbidities","description":"Weight management for those with diabetes, hypertension, PCOS, fatty liver, and dyslipidemia — where weight loss is medically essential for controlling these conditions and preventing long-term organ damage."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Post-Pregnancy Weight & Body Reshaping","description":"Supervised, safe post-partum weight management and body reshaping programs including Ayurvedic therapies particularly suited for post-pregnancy recovery and weight normalization."}]},"treatments":{"sectionLabel":"SLIMMING SERVICES","sectionTitle":"Comprehensive Slimming Program","sectionSupport":"Multi-dimensional, medically supervised slimming combining exercise, nutrition, Ayurveda, and medical management.","steps":[{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Slimming Therapies","description":"Udwarthanam (dry powder massage therapy) is the most powerful Ayurvedic slimming therapy — a vigorous, stimulating massage using specially formulated herbal powders that improves lymphatic drainage, reduces subcutaneous fat deposition, and dramatically boosts metabolism. Medicated steam bath (Swedana) and Panchakarma Virechana (therapeutic purgation) eliminate accumulated metabolic toxins (Ama). Medohar Guggulu, Triphala, and Varanadi Kashayam Ayurvedic formulations regulate fat metabolism."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Supervised Exercise Rehabilitation","description":"Medically supervised, heart-rate-monitored exercise programs designed for safe, effective fat loss. Cardiovascular conditioning in our hydrotherapy pool (ideal for joint pain and early-stage obesity). Progressive land-based aerobic exercise and resistance training using the Huber 360 platform as fitness improves. High-Intensity Interval Training (HIIT) for advanced participants. All programs are individually designed and progression-monitored."},{"image":"Assets/rehab/th_ayurveda.webp","title":"Medical Nutrition & Dietary Counseling","description":"Comprehensive dietary assessment and individualized meal planning combining modern nutritional science with Ayurvedic dietary principles. Caloric targets based on metabolic rate assessment. Macronutrient optimization for fat loss while preserving lean muscle mass. Meal timing strategies (intermittent fasting, chrononutrition). Cultural, practical, and taste preferences respected throughout."},{"image":"Assets/rehab/prog_stroke.webp","title":"Medical Weight Management","description":"Hormonal evaluation (thyroid, insulin resistance, PCOS), anti-obesity pharmacotherapy when indicated, management of weight-related comorbidities (diabetes, hypertension), sleep apnea diagnosis and management, and behavioral counseling for emotional eating and sustainable lifestyle change."}]},"technologies":{"sectionLabel":"SLIMMING TECHNOLOGY","sectionTitle":"Advanced Slimming Treatment Technology","sectionSupport":"Science-based slimming technology integrated with Ayurvedic therapies for comprehensive body transformation.","cards":[{"icon":"leaf","title":"Udwarthanam Therapy","description":"Vigorous herbal powder massage boosting metabolism, improving lymphatic drainage, and reducing subcutaneous fat — the cornerstone of Ayurvedic slimming treatment."},{"icon":"waves","title":"Hydrotherapy Cardiovascular Training","description":"Water-based cardiovascular exercise enabling effective fat-burning workout without the joint stress that prevents many overweight patients from exercising on land."},{"icon":"activity","title":"DEXA Body Composition Analysis","description":"Dual-energy X-ray absorptiometry (DEXA) scan providing precise body fat percentage, lean mass, and regional body composition — the gold standard for monitoring slimming progress."},{"icon":"ruler","title":"Metabolic Rate Assessment","description":"Resting metabolic rate (RMR) measurement enabling precise caloric targets for fat loss — eliminating guesswork and ensuring the dietary plan is physiologically individualized."},{"icon":"sun","title":"Yoga for Weight Management","description":"Specialized yoga and Pranayama programs for weight management — improving metabolic function, reducing stress cortisol (a major driver of abdominal fat), and building the mindfulness that supports sustainable lifestyle change."}]},"faq":{"sectionSupport":"Find answers to key details about the Slimming Treatment program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Slimming Treatment combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","K-JbXaLK410wPiD2XlXa9",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
