 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["spinal-cord-injury",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","spinal-cord-injury","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"spinal-cord-injury","sidebarId":"spinal-cord","metaTitle":"Spinal Cord Injury Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Rebuilding trunk control, sensory awareness, and mobility post-spinal trauma through integrated physical and traditional therapies.","canonicalPath":"/spinal-cord-injury","hero":{"bannerImage":"Assets/AG Sub-pages Banner/New/Spinal Cord Injury.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Spinal Cord Injury","subtitle":"Rebuilding trunk control, sensory awareness, and mobility post-spinal trauma through integrated physical and traditional therapies."},"overview":{"sectionLabel":"OVERVIEW","title":"Spinal Cord Injury Rehabilitation: Rebuilding Life, Restoring Function","paragraphs":["A spinal cord injury (SCI) is one of the most life-altering events a person can experience, often resulting in sudden, dramatic loss of motor function and sensation below the level of injury. The impact extends far beyond the physical — it touches every aspect of independence, identity, and quality of life.","At Ayurgreen Hospital, we provide a comprehensive, compassionate, and cutting-edge Spinal Cord Injury Rehabilitation Program. As India's first robotic-integrated neuro rehabilitation center, we combine the most advanced robotic exoskeletons and functional electrical stimulation with world-class physiotherapy and authentic Kerala Ayurvedic therapies.","Our program is built on the science of neuroplasticity — the brain and spinal cord's remarkable ability to form new neural connections. Through high-repetition, task-specific training delivered by our robotic systems, combined with the internal healing power of Ayurveda, we help patients with both complete and incomplete SCI maximize their functional recovery."],"image":"Assets/Whatsapp%20Icon.webp","imageAlt":"Spinal Cord Injury at Ayurgreen Hospital"},"conditions":{"sectionLabel":"INJURY TYPES WE TREAT","sectionTitle":"Spinal Cord Injury Types We Rehabilitate","sectionSupport":"Our SCI Rehabilitation Program is tailored to all injury levels, from cervical to lumbar, and all AIS classifications.","cards":[{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Incomplete Spinal Cord Injuries","description":"AIS B, C, and D injuries with preserved sensation or motor function below the injury level. Our intensive robotic and physiotherapy programs target the spared neural pathways to maximize functional gain and recovery of walking and hand function."},{"image":"Assets/rehab/prog_stroke.webp","title":"Complete Spinal Cord Injuries (AIS A)","description":"For complete injuries with no preserved function below the injury level, our program focuses on maximizing independence with adaptive equipment, preventing secondary complications (pressure sores, UTIs, spasticity), and maintaining musculoskeletal health through standing and weight-bearing programs."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Quadriplegia & Paraplegia","description":"Specialized rehabilitation for cervical injuries causing quadriplegia (arm and leg weakness) and thoracic/lumbar injuries causing paraplegia (leg weakness). Robotic gait training, Armotion arm therapy, and functional electrical stimulation are customized to each injury level."}]},"treatments":{"sectionLabel":"TREATMENT PROGRAM","sectionTitle":"Comprehensive SCI Rehabilitation Services","sectionSupport":"A multidisciplinary program combining robotic technology, Ayurveda, physiotherapy, and neuro-urology for complete SCI care.","steps":[{"image":"Assets/rehab/th_robotic.webp","title":"Robotic Gait & Functional Rehabilitation","description":"The G-EO System robotic gait trainer provides weight-supported walking practice for even the most severely injured SCI patients — stimulating spinal cord circuits and promoting neuroplasticity. For cervical injuries, the Armotion robotic arm system rebuilds hand and arm function. Functional Electrical Stimulation (FES) cycles are used to maintain muscle bulk and improve circulation in paralyzed limbs."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Neurological Therapies for SCI","description":"Specialized Kerala Ayurvedic treatments targeting the nervous system: Abhyanga (therapeutic oil massage) to reduce spasticity and stimulate sensory pathways; Kizhi (herbal bundle therapy) to improve circulation in paralyzed limbs; Basti (medicated enema) for neurogenic bowel management; and powerful Medhya Rasayana formulations to support nerve regeneration and neuroprotection."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Specialized SCI Physiotherapy & OT","description":"Comprehensive physiotherapy for respiratory muscle training (critical for high cervical injuries), passive range of motion, strengthening of preserved muscle groups, sitting balance, and transfer training. Occupational therapy focuses on maximizing upper limb function and independence in activities of daily living (ADLs) including eating, grooming, and self-care using adaptive equipment."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Secondary Complication Prevention & Management","description":"SCI patients face significant secondary medical complications. Our integrated team manages: Neurogenic Bladder (urodynamics, CIC training, Botox); Neurogenic Bowel (bowel management programs); Pressure Ulcer Prevention (specialized mattresses, positioning programs); Spasticity Management (Baclofen, Botox, physiotherapy); Autonomic Dysreflexia recognition and management; and DVT prevention protocols."}]},"technologies":{"sectionLabel":"SCI TECHNOLOGY","sectionTitle":"Advanced SCI Rehabilitation Technology","sectionSupport":"India's most advanced robotic and functional technology for spinal cord injury recovery.","cards":[{"icon":"bot","title":"G-EO Robotic Gait Trainer","description":"Weight-supported robotic gait training simulating walking and stair climbing — providing 1,000+ steps per session to stimulate spinal cord neural circuits below the injury level."},{"icon":"hand","title":"Armotion Robotic Arm Therapy","description":"Robotic upper extremity rehabilitation for cervical SCI patients, rebuilding shoulder, elbow, and wrist coordination through sensor-guided, high-repetition training."},{"icon":"zap","title":"Functional Electrical Stimulation (FES)","description":"Computer-controlled electrical stimulation of paralyzed muscles to maintain bulk, improve circulation, and in incomplete injuries, assist voluntary movement and walking."},{"icon":"waves","title":"Hydrotherapy (AquaCiser III)","description":"Underwater treadmill allowing weight-bearing walking practice with buoyancy support — ideal for SCI patients beginning to bear partial weight on recovering limbs."},{"icon":"leaf","title":"Ayurvedic Neuro-Regeneration","description":"Medhya Rasayana formulations and nerve-stimulating Ayurvedic therapies (Abhyanga, Kizhi) supporting neuroplasticity and reducing spasticity alongside robotic rehabilitation."}]},"faq":{"sectionSupport":"Find answers to key details about the Spinal Cord Injury program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Spinal Cord Injury combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","nTYTulZ5_jDGw03IIh65O",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
