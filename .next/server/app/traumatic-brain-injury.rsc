margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["traumatic-brain-injury",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","traumatic-brain-injury","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"traumatic-brain-injury","sidebarId":"tbi","metaTitle":"Traumatic Brain Injury Rehabilitation & Care | Ayurgreen Hospital","metaDescription":"Complex sensory, physical, and cognitive retraining protocols to help reorganize neural circuits post-head trauma.","canonicalPath":"/traumatic-brain-injury","hero":{"bannerImage":"Assets/AG Sub-pages Banner/New/Traumatic Brain Injury.webp","label":"Rehabilitation Program","breadcrumbCategory":"Specialities","title":"Traumatic Brain Injury","subtitle":"Complex sensory, physical, and cognitive retraining protocols to help reorganize neural circuits post-head trauma."},"overview":{"sectionLabel":"OVERVIEW","title":"Traumatic Brain Injury Rehabilitation: Rebuilding the Brain","paragraphs":["Traumatic Brain Injury (TBI) occurs when a sudden physical force causes damage to the brain — from road traffic accidents, falls, assault, or sports injuries. The consequences are as varied as the brain itself: physical disabilities, cognitive impairments, behavioral changes, emotional dysregulation, and sensory deficits.","At Ayurgreen Hospital, our TBI Rehabilitation Program is one of the most comprehensive in India. We understand that recovering from a TBI is not a single, linear process — it requires simultaneous, coordinated care from neurologists, neurosurgeons, rehabilitation physicians, physiotherapists, occupational therapists, speech therapists, neuropsychologists, and Ayurvedic physicians.","Our program utilizes the science of neuroplasticity — the brain's extraordinary capacity to reorganize itself and form new neural pathways — through high-intensity, repetitive robotic training combined with the profound internal healing power of authentic Kerala Ayurveda, creating recovery outcomes that were previously impossible."],"image":"Assets/rehab/prog_tbi.webp","imageAlt":"Traumatic Brain Injury at Ayurgreen Hospital"},"conditions":{"sectionLabel":"TBI SEVERITY & TYPES","sectionTitle":"TBI Conditions We Rehabilitate","sectionSupport":"Our TBI program is tailored to all severity levels and all categories of traumatic brain injury.","cards":[{"image":"Assets/rehab/prog_tbi.webp","title":"Severe TBI & Disorders of Consciousness","description":"Patients recovering from prolonged coma, vegetative state, and minimally conscious state. Our program uses sensory stimulation, robotic assisted movement, and Ayurvedic therapies to promote emergence and maximize functional recovery."},{"image":"Assets/rehab/prog_stroke.webp","title":"Moderate TBI with Significant Deficits","description":"Patients with significant motor, cognitive, behavioral, and communication deficits following moderate TBI. Our intensive inpatient program targets all deficit areas simultaneously with specialized therapists."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Mild TBI & Post-Concussion Syndrome","description":"Persistent symptoms following mild TBI including headache, dizziness, cognitive fog, fatigue, sleep disturbance, and mood changes. Our integrated program addresses all post-concussion symptoms comprehensively."}]},"treatments":{"sectionLabel":"REHABILITATION PROGRAM","sectionTitle":"Comprehensive TBI Rehabilitation Services","sectionSupport":"A simultaneous, multidisciplinary attack on all TBI deficits — motor, cognitive, emotional, and communicative.","steps":[{"image":"Assets/rehab/th_robotic.webp","title":"Robotic Motor Rehabilitation","description":"For TBI patients with significant motor deficits (hemiplegia, spasticity, balance impairment), our robotic systems provide the high-repetition, precisely guided movement that is the most powerful driver of neuroplasticity. The G-EO gait trainer rebuilds walking ability; the Armotion system addresses arm function; and the Huber 360 restores balance and core stability."},{"image":"Assets/rehab/th_speech.webp","title":"Speech, Language & Cognitive Rehabilitation","description":"Comprehensive speech and language therapy for aphasia, dysarthria, and dysphagia following TBI. Neuropsychological cognitive rehabilitation targeting attention, memory, executive function, and processing speed. Virtual Reality cognitive training provides engaging, measurable, and adaptive cognitive therapy."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Brain Healing Therapies","description":"Powerful Medhya Rasayana (brain-enhancing) Ayurvedic formulations including Brahmi, Shankhapushpi, and Ashwagandha support neuroprotection and cognitive recovery. Shirodhara (medicated oil poured on the forehead) profoundly calms the nervous system and reduces TBI-related anxiety, sleep disturbance, and emotional lability. Nasyam (nasal oil therapy) directly stimulates brain centers."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Occupational Therapy & Behavioral Management","description":"Occupational therapy for retraining all activities of daily living, including adaptive strategies for cognitive and motor deficits. Behavioral management programs for TBI-related aggression, impulsivity, and disinhibition. Structured behavioral frameworks consistent across all team members ensure safe, therapeutic environments for patients with significant behavioral challenges."}]},"technologies":{"sectionLabel":"TBI TECHNOLOGY","sectionTitle":"Advanced TBI Rehabilitation Technology","sectionSupport":"Cutting-edge neurological rehabilitation technology for every dimension of traumatic brain injury recovery.","cards":[{"icon":"bot","title":"Robotic Motor Rehabilitation","description":"G-EO gait trainer and Armotion arm system providing high-repetition, precisely guided motor training to stimulate neuroplasticity and rebuild motor function after TBI."},{"icon":"headset","title":"VR Cognitive Rehabilitation","description":"Immersive virtual reality environments for engaging cognitive training targeting attention, memory, executive function, and spatial orientation — measurable and adaptive to patient progress."},{"icon":"brain","title":"Neuropsychological Assessment","description":"Comprehensive standardized cognitive testing (WAIS, WMS, MoCA, RBMT) to precisely map cognitive deficits and track recovery over time."},{"icon":"leaf","title":"Medhya Rasayana Therapy","description":"Brain-enhancing Ayurvedic formulations (Brahmi, Ashwagandha) and calming therapies (Shirodhara, Nasyam) supporting neuroprotection, cognitive recovery, and emotional regulation."},{"icon":"activity","title":"Huber 360 Balance Training","description":"Dynamic balance and core stabilization training using the Huber 360 platform — essential for TBI patients with vestibular dysfunction and postural instability."}]},"faq":{"sectionSupport":"Find answers to key details about the Traumatic Brain Injury program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Traumatic Brain Injury combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","--Vi51gEsmRwaDPliug38",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
