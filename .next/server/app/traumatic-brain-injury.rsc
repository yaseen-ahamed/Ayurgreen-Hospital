8:T699,{"@context":"https://schema.org","@graph":[{"@type":"MedicalOrganization","@id":"https://ayurgreenhospital.com/#organization","name":"Ayurgreen Hospital","url":"https://ayurgreenhospital.com/","logo":"https://ayurgreenhospital.com/Assets/Ayurgreen_Logo.webp","contactPoint":{"@type":"ContactPoint","telephone":"+91-89430-55555","contactType":"customer service","email":"info@ayurgreenhospitals.com","availableLanguage":["en","ar"]}},{"@type":"MedicalWebPage","@id":"https://ayurgreenhospital.com/traumatic-brain-injury#webpage","url":"https://ayurgreenhospital.com/traumatic-brain-injury","name":"Traumatic Brain Injury Rehabilitation & Care | Ayurgreen Hospital","description":"Complex sensory, physical, and cognitive retraining protocols to help reorganize neural circuits post-head trauma.","about":{"@type":"MedicalSpecialty","name":"Integrated Traumatic Brain Injury Rehabilitation"}},{"@type":"BreadcrumbList","@id":"https://ayurgreenhospital.com/traumatic-brain-injury#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":2,"name":"Specialities","item":"https://ayurgreenhospital.com/"},{"@type":"ListItem","position":3,"name":"Traumatic Brain Injury","item":"https://ayurgreenhospital.com/traumatic-brain-injury"}]},{"@type":"Service","@id":"https://ayurgreenhospital.com/traumatic-brain-injury#service","name":"Traumatic Brain Injury Rehabilitation","provider":{"@type":"Hospital","name":"Ayurgreen Hospital"},"serviceType":"Rehabilitation Service","description":"Complex sensory, physical, and cognitive retraining protocols to help reorganize neural circuits post-head trauma."}]}0:{"P":null,"b":"8fOA1jbl6pU7Z3DXp6zXJ","p":"","c":["","traumatic-brain-injury"],"i":false,"f":[[["",{"children":["traumatic-brain-injury",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/4c4fc651