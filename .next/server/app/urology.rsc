:["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["urology",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","urology","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"urology","sidebarId":"urology","metaTitle":"Urology | Ayurgreen Hospital","metaDescription":"Integrated bladder and bowel dysfunction management, pelvic muscle retraining, and clinical tracking for post-spinal patients.","canonicalPath":"/urology","hero":{"bannerImage":"Assets/rehab/prog_spinal_cord.webp","label":"Modern Integrations","breadcrumbCategory":"Modern Integrations","title":"Urology","subtitle":"Integrated bladder and bowel dysfunction management, pelvic muscle retraining, and clinical tracking for post-spinal patients."},"overview":{"sectionLabel":"OVERVIEW","title":"Urology: Specialized Care for the Urinary System","paragraphs":["Urological conditions affecting the kidneys, bladder, and urinary tract are among the most common yet undertreated medical issues. They significantly impact daily life, personal dignity, and quality of life. Expert, compassionate urological care is essential to restore normal function and confidence.","At Ayurgreen Hospital, our Urology Department provides a comprehensive range of urological services for adults of all ages. Our urologists are particularly expert in managing the complex neurogenic bladder and urological complications that frequently arise in patients with spinal cord injuries, stroke, and multiple sclerosis.","This expertise in neuro-urology sets us apart as a center uniquely capable of providing truly comprehensive rehabilitation for neurological patients — addressing both their physical recovery AND their urological health in one seamlessly integrated program."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Urology at Ayurgreen Hospital"},"conditions":{"sectionLabel":"CONDITIONS WE TREAT","sectionTitle":"Urological Conditions We Specialize In","sectionSupport":"Expert medical and surgical management for the full range of adult urological conditions including complex neuro-urology.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Neurogenic Bladder","description":"Complex bladder dysfunction resulting from neurological conditions — the most critical urological issue in our rehabilitation population. Expert urodynamic assessment and management for stroke, SCI, MS, and Parkinson's patients to prevent kidney damage and restore bladder control."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Prostate & Voiding Disorders","description":"Benign prostate hyperplasia (BPH), prostate cancer screening, urinary incontinence, and overactive bladder. Minimally invasive surgical and medical options tailored to patient need and lifestyle."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Kidney & Stone Disease","description":"Comprehensive management of kidney stones (nephrolithiasis), urinary tract infections (including complicated UTIs in catheterized patients), and kidney cyst management."}]},"treatments":{"sectionLabel":"UROLOGICAL SERVICES","sectionTitle":"Comprehensive Urological Care","sectionSupport":"Expert urological care for both standard conditions and the complex neuro-urological needs of our rehabilitation patients.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"Urodynamic Studies & Neurogenic Bladder Management","description":"Expert urodynamic studies (cystometry, pressure flow studies) are used to precisely diagnose the type of neurogenic bladder dysfunction in our rehabilitation patients. Based on this, our urologists design comprehensive bladder management programs including clean intermittent catheterization (CIC) training, anticholinergic medications, Botox intravesical injections, and neuromodulation — protecting kidney function and dramatically improving patient independence and dignity."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"Pelvic Floor & Bladder Rehabilitation","description":"Working in close collaboration with our physiotherapy and occupational therapy teams, urological rehabilitation focuses on pelvic floor retraining, bladder retraining programs, and the establishment of sustainable, safe catheter management routines that patients and caregivers can manage at home."},{"image":"Assets/rehab/th_panchakarma.webp","title":"Ayurvedic Urological Support","description":"Powerful Ayurvedic renal and urinary tonics (Punarnava, Gokshura, Shilajit formulations) support bladder health, reduce inflammation, and enhance natural diuretic and anti-infective properties. These are integrated into our urological management programs to provide a comprehensive, holistic approach to urinary system health."},{"image":"Assets/rehab/th_robotic.webp","title":"Minimally Invasive Urological Surgery","description":"Endoscopic procedures for stone removal (Ureteroscopy, PCNL), TURP for BPH, and cystoscopy for bladder diagnosis. Our minimally invasive approach means shorter hospital stays, less pain, and faster recovery — essential for patients also undergoing intensive rehabilitation."}]},"technologies":{"sectionLabel":"UROLOGICAL TECHNOLOGY","sectionTitle":"Advanced Urological Capabilities","sectionSupport":"State-of-the-art urological diagnostics and minimally invasive surgery for precise, effective treatment.","cards":[{"icon":"activity","title":"Urodynamic Suite","description":"Comprehensive multi-channel urodynamic testing including cystometry, pressure flow studies, video urodynamics, and electromyography for precise diagnosis of bladder dysfunction."},{"icon":"droplet","title":"Flexible & Rigid Cystoscopy","description":"Advanced endoscopic visualization of the bladder and urethra for diagnosis and treatment of bladder pathology including stones, tumors, and strictures."},{"icon":"syringe","title":"Intravesical Botox","description":"Botulinum toxin injections into the bladder for severe neurogenic overactive bladder — dramatically reducing incontinence and urgency in rehabilitation patients."},{"icon":"leaf","title":"Ayurvedic Renal Tonics","description":"Punarnava, Gokshura, and Shilajit-based formulations supporting kidney filtration, bladder health, and urinary tract immunity as an integral part of the management program."},{"icon":"shield-plus","title":"UTI Prevention Protocols","description":"Specialized infection prevention protocols for catheter-dependent rehabilitation patients, significantly reducing catheter-associated urinary tract infection rates."}]},"faq":{"sectionSupport":"Find answers to key details about the Urology program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Urology combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","Bk8N-o7sT7hGWxZVzMDJE",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
