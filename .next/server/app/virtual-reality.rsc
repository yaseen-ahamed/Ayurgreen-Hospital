uppressHydrationWarning":true,"children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href":"https://fonts.gstatic.com","crossOrigin":""}],["$","link",null,{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap","rel":"stylesheet"}],["$","$L2",null,{"src":"https://unpkg.com/lucide@latest","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js","strategy":"beforeInteractive"}],["$","$L2",null,{"src":"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js","strategy":"beforeInteractive"}]]}],["$","body",null,{"suppressHydrationWarning":true,"children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","main",null,{"children":["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[[],[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":404}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]]}]]}],{"children":["virtual-reality",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","virtual-reality","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$8"}}],["$","$L9",null,{"data":{"slug":"virtual-reality","sidebarId":"virtual-reality","metaTitle":"Virtual Reality | Ayurgreen Hospital","metaDescription":"Immersive cognitive and sensory retraining utilizing advanced virtual reality software to promote rapid neural plastic growth.","canonicalPath":"/virtual-reality","hero":{"bannerImage":"Assets/rehab/th_vr.webp","label":"Departments","breadcrumbCategory":"Departments","title":"Virtual Reality","subtitle":"Immersive cognitive and sensory retraining utilizing advanced virtual reality software to promote rapid neural plastic growth."},"overview":{"sectionLabel":"OVERVIEW","title":"Virtual Reality Rehabilitation: Immersive Technology for Faster Recovery","paragraphs":["Virtual Reality (VR) rehabilitation is one of the most exciting frontiers in modern medicine. By immersing patients in interactive, three-dimensional virtual environments, VR enables intensive, engaging, and measurable practice of movements and cognitive tasks that are impossible in conventional therapy settings.","At Ayurgreen Hospital, our VR Rehabilitation Suite is at the forefront of therapeutic innovation. VR is used both as a standalone intervention and as a powerful complement to our robotic systems, physiotherapy, and cognitive rehabilitation programs.","The scientific basis for VR rehabilitation is rooted in neuroplasticity — the brain's remarkable ability to form new neural connections in response to repetitive, task-specific training. VR provides this training in a uniquely engaging, motivating, and measurable way, enhancing patient adherence and accelerating recovery outcomes."],"image":"Assets/rehab/prog_stroke.webp","imageAlt":"Virtual Reality at Ayurgreen Hospital"},"conditions":{"sectionLabel":"VR APPLICATIONS","sectionTitle":"VR Rehabilitation Indications","sectionSupport":"Evidence-based VR rehabilitation for motor, cognitive, psychological, and pain management applications.","cards":[{"image":"Assets/rehab/prog_stroke.webp","title":"Motor Rehabilitation","description":"Post-stroke hemiplegia, TBI motor deficits, Parkinson's gait training, balance disorders, and post-orthopedic rehabilitation. VR provides task-specific, high-repetition motor training in engaging game-like environments."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"Cognitive Rehabilitation","description":"Post-stroke and TBI cognitive deficits — memory, attention, processing speed, and executive function impairment. VR cognitive training provides adaptive, measurable, and highly engaging cognitive rehabilitation."},{"image":"Assets/rehab/prog_parkinsons.webp","title":"Pain Management & Psychological Applications","description":"VR distraction therapy for procedural and chronic pain, VR exposure therapy for PTSD and phobias, and VR mindfulness environments for anxiety and stress management."}]},"treatments":{"sectionLabel":"VR APPLICATIONS","sectionTitle":"Virtual Reality Rehabilitation Services","sectionSupport":"Evidence-based VR therapy integrated within our comprehensive neurological and physical rehabilitation programs.","steps":[{"image":"Assets/rehab/prog_stroke.webp","title":"VR Motor & Gait Rehabilitation","description":"Immersive VR environments for task-specific motor training: reaching tasks in 3D space for hemiplegic arm recovery, balance games for postural training in Parkinson's and stroke, VR gait training with visual cues for freezing of gait, and mirror therapy VR for phantom limb pain and hemiplegia. The engaging nature of VR dramatically increases the repetitions patients perform voluntarily — the key driver of motor recovery."},{"image":"Assets/rehab/prog_spinal_cord.webp","title":"VR Cognitive Rehabilitation","description":"Adaptive VR cognitive training programs targeting the specific cognitive deficits identified in neuropsychological assessment. Attention training in dynamic VR environments, spatial navigation tasks for memory rehabilitation, multi-task training for executive function, and VR daily living simulations (virtual kitchen, virtual shop) for real-world functional cognitive rehabilitation."},{"image":"Assets/rehab/th_panchakarma.webp","title":"VR Pain Management & Desensitization","description":"VR distraction therapy reduces procedural pain (wound dressing, physiotherapy mobilization) and chronic neuropathic pain by redirecting neural processing resources away from pain signals. Graded exposure VR for CRPS desensitization and post-SCI pain management. VR mindfulness and relaxation programs for stress and anxiety reduction."},{"image":"Assets/rehab/th_physiotherapy.webp","title":"VR Social Skills & Vocational Training","description":"VR social skills training for autism spectrum disorder — providing safe, repeatable practice of complex social scenarios. VR vocational simulations for work hardening and return-to-work training. VR driving assessment environments for evaluating fitness to drive after neurological injury."}]},"technologies":{"sectionLabel":"VR TECHNOLOGY","sectionTitle":"Advanced VR Rehabilitation Technology","sectionSupport":"Cutting-edge VR systems providing immersive, measurable, and engaging rehabilitation experiences.","cards":[{"icon":"headset","title":"Immersive VR Headsets","description":"High-resolution, low-latency VR headsets providing fully immersive 360° environments for motor, cognitive, and psychological rehabilitation applications."},{"icon":"activity","title":"Motion Capture & Tracking","description":"Full-body motion tracking systems enabling precise measurement of movement quality and progress during VR motor rehabilitation."},{"icon":"brain","title":"Adaptive Cognitive VR Programs","description":"AI-driven adaptive VR cognitive training programs that automatically adjust difficulty based on patient performance — ensuring optimal challenge for maximum cognitive rehabilitation benefit."},{"icon":"bot","title":"VR-Robotic Integration","description":"Integration of VR environments with our robotic rehabilitation systems (G-EO, Armotion) — providing immersive VR gaming environments that enhance motivation during robotic gait and arm training."},{"icon":"leaf","title":"VR Mindfulness & Nature Environments","description":"Calming virtual nature environments integrated with Ayurvedic meditation and Yoga Nidra practices for stress management, anxiety reduction, and sleep improvement."}]},"faq":{"sectionSupport":"Find answers to key details about the Virtual Reality program.","items":[{"question":"What is the recovery protocol for this program?","answer":"Our recovery protocol for Virtual Reality combines daily intensive rehabilitation therapies (robotic support and physical therapy) with personalized Ayurvedic nerve nourishment and systemic detoxification to accelerate functional gains."},{"question":"How long is the typical inpatient stay?","answer":"Most inpatient stays range from 14 to 28 days. A comprehensive assessment is conducted on arrival to map specific milestones, timelines, and discharge pathways."},{"question":"Is robotic therapy safe for all patients?","answer":"Yes, robotic training is safe and is adjusted based on muscle strength, joint ranges, and fatigue levels. Every session is directly supervised by certified clinical engineers and therapists."},{"question":"Are the Ayurvedic medicines safe?","answer":"All herbal oils and medicines are sourced from GMP-certified traditional pharmacies and undergo rigorous testing. They are prescribed specifically to match the patient's biological state."},{"question":"Can we coordinate with our existing neurologist?","answer":"Absolutely. We encourage multidisciplinary alignment and coordinate closely with the patient's referring clinicians to ensure continuity of care."},{"question":"What is the daily therapy schedule?","answer":"A typical day includes active physical and robotic rehabilitation in the morning, followed by relaxing Ayurvedic therapies and counseling sessions in the afternoon."},{"question":"Do you offer post-discharge support?","answer":"Yes, we provide detailed home-exercise regimens, custom orthotic consultations, and online follow-ups to ensure patients maintain their functional gains."},{"question":"How do I book a consultation?","answer":"You can book a virtual consultation by submitting your medical records online, messaging our coordinators via WhatsApp, or calling our helpline directly."}]}}}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/6e9fffbbd38092f6.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","iP88p0UR1Wy8rjNSSKzBa",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
